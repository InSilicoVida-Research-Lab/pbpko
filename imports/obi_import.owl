SubClassOf(pbpko:IAO_0000078 pbpko:IAO_0000102)

# Class: pbpko:IAO_0000098 (data format specification)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000098 "A data format specification is the information content borne by the document published defining the specification.
Example: The ISO document specifying what encompasses an XML document; The instructions in a XSD file"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000098 "data format specification"@en)
SubClassOf(pbpko:IAO_0000098 pbpko:IAO_0000033)

# Class: pbpko:IAO_0000100 (homogenous data collection)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000100 "A data item that is an aggregate of other data items of the same type that have something in common. Averages and distributions can be determined for data sets."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000100 "homogenous data collection"@en)
SubClassOf(pbpko:IAO_0000100 pbpko:IAO_0000027)

# Class: pbpko:IAO_0000101 (image)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000101 "An image is an affine projection to a two dimensional surface, of measurements of some quality of an entity or entities repeated at regular intervals across a spatial range, where the measurements are represented as color and luminosity on the projected on surface."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000101 "image"@en)
SubClassOf(pbpko:IAO_0000101 pbpko:IAO_0000308)

# Class: pbpko:IAO_0000102 (data about an ontology part)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000102 "Data about an ontology part is a data item about a part of an ontology, for example a term"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000102 "Person:Alan Ruttenberg"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000102 "data about an ontology part"@en)
SubClassOf(pbpko:IAO_0000102 pbpko:IAO_0000027)

# Class: pbpko:IAO_0000104 (plan specification)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000104 "A directive information entity with action specifications and objective specifications as parts, and that may be concretized as a realizable entity that, if realized, is realized in a process in which the bearer tries to achieve the objectives by taking the actions specified."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000104 "plan specification"@en)
SubClassOf(pbpko:IAO_0000104 pbpko:IAO_0000033)

# Class: pbpko:IAO_0000179 (histogram)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000179 "A histogram is a report graph which is a statistical description of a
distribution in terms of occurrence frequencies of different event classes."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000179 "histogram"@en)
SubClassOf(pbpko:IAO_0000179 pbpko:IAO_0000038)

# Class: pbpko:IAO_0000180 (heatmap)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000180 "A heatmap is a report graph which is a graphical representation of data
where the values taken by a variable(s) are shown as colors in a
two-dimensional map."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000180 "heatmap"@en)
SubClassOf(pbpko:IAO_0000180 pbpko:IAO_0000038)

# Class: pbpko:IAO_0000183 (dendrogram)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000183 "A dendrogram is a report graph which is a tree diagram
frequently used to illustrate the arrangement of the clusters produced by a
clustering algorithm."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000183 "dendrogram"@en)
SubClassOf(pbpko:IAO_0000183 pbpko:IAO_0000038)

# Class: pbpko:IAO_0000184 (scatter plot)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000184 "A scatterplot is a graph which uses Cartesian coordinates to display values for two variables for a set of data. The data is displayed as a collection of points, each having the value of one variable determining the position on the horizontal axis and the value of the other variable determining the position on the vertical axis."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000184 "scatter plot"@en)
SubClassOf(pbpko:IAO_0000184 pbpko:IAO_0000038)

# Class: pbpko:IAO_0000225 (obsolescence reason specification)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000225 "The reason for which a term has been deprecated. The allowed values come from an enumerated list of predefined terms. See the specification of these instances for more detailed definitions of each enumerated value."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000225 "PERSON: Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000225 "PERSON: Melanie Courtot"@en)
