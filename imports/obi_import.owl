# Class: pbpko:OBI_0000663 (class prediction data transformation)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000663 "A class prediction data transformation (sometimes called supervised classification) is a data transformation that has objective class prediction."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000663 "James Malone")
AnnotationAssertion(rdfs:label pbpko:OBI_0000663 "class prediction data transformation"@en)
EquivalentClasses(pbpko:OBI_0000663 ObjectUnionOf(ObjectSomeValuesFrom(pbpko:OBI_0000299 pbpko:OBI_0000023) ObjectSomeValuesFrom(pbpko:OBI_0000417 pbpko:OBI_0200179)))
SubClassOf(pbpko:OBI_0000663 pbpko:OBI_0200000)

# Class: pbpko:OBI_0000684 (specimen collection objective)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000684 "A objective specification that is fulfilled by obtaining a material entity for potential use as an input upon which measurements or observations are performed."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000684 "Bjoern Peters")
AnnotationAssertion(rdfs:label pbpko:OBI_0000684 "specimen collection objective")
SubClassOf(pbpko:OBI_0000684 pbpko:IAO_0000005)

# Class: pbpko:OBI_0000700 (support vector machine)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000700 "A support vector machine is a data transformation with a class prediction objective based on the construction of a separating hyperplane that maximizes the margin between two data sets of vectors in n-dimensional space."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000700 "James Malone")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000700 "Ryan Brinkman")
AnnotationAssertion(rdfs:label pbpko:OBI_0000700 "support vector machine")
SubClassOf(pbpko:OBI_0000700 pbpko:OBI_0000663)
SubClassOf(pbpko:OBI_0000700 ObjectSomeValuesFrom(pbpko:OBI_0000417 pbpko:OBI_0200179))

# Class: pbpko:OBI_0000704 (decision tree induction objective)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000704 "A decision tree induction objective is a data transformation objective in which a tree-like graph of edges and nodes is created and from which the selection of each branch requires that some type of logical decision is made."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000704 "James Malone")
AnnotationAssertion(rdfs:label pbpko:OBI_0000704 "decision tree induction objective")
SubClassOf(pbpko:OBI_0000704 pbpko:OBI_0200166)

# Class: pbpko:OBI_0000707 (decision tree building data transformation)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000707 "A decision tree building data transformation is a data transformation that has objective decision tree induction."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000707 "James Malone")
AnnotationAssertion(rdfs:label pbpko:OBI_0000707 "decision tree building data transformation"@en)
EquivalentClasses(pbpko:OBI_0000707 ObjectSomeValuesFrom(pbpko:OBI_0000417 pbpko:OBI_0000704))
SubClassOf(pbpko:OBI_0000707 pbpko:OBI_0200000)

# Class: pbpko:OBI_0000713 (GenePattern software)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000713 "a software that provides access to more than 100 tools for gene expression analysis, proteomics, SNP analysis and common data processing tasks."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000713 "James Malone")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000713 "Person:Helen Parkinson")
AnnotationAssertion(rdfs:label pbpko:OBI_0000713 "GenePattern software")
SubClassOf(pbpko:OBI_0000713 pbpko:IAO_0000010)

# Class: pbpko:OBI_0000726 (peak matching)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000726 "Peak matching is a data transformation performed on a dataset of a graph of ordered data points (e.g. a spectrum) with the objective of pattern matching local maxima above a noise threshold"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000726 "James Malone")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000726 "Ryan Brinkman")
AnnotationAssertion(rdfs:label pbpko:OBI_0000726 "peak matching")
SubClassOf(pbpko:OBI_0000726 pbpko:OBI_0200000)

# Class: pbpko:OBI_0000727 (k-nearest neighbors)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000727 "A k-nearest neighbors is a data transformation which achieves a class discovery or partitioning objective, in which an input data object with vector y is assigned to a class label based upon the k closest training data set points to y; where k is the largest value that class label is assigned."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000727 "James Malone"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0000727 "k-nearest neighbors"@en)
SubClassOf(pbpko:OBI_0000727 pbpko:OBI_0200171)
SubClassOf(pbpko:OBI_0000727 pbpko:OBI_0200175)
