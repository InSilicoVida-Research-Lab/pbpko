SubClassOf(pbpko:IAO_0000225 pbpko:IAO_0000102)

# Class: pbpko:IAO_0000308 (figure)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000308 "An information content entity consisting of a two dimensional arrangement of information content entities such that the arrangement itself is about something."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000308 "figure"@en)
SubClassOf(pbpko:IAO_0000308 pbpko:IAO_0000030)

# Class: pbpko:IAO_0000310 (document)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000310 "A collection of information content entities intended to be understood together as a whole"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000310 "document"@en)
SubClassOf(pbpko:IAO_0000310 pbpko:IAO_0000030)

# Class: pbpko:IAO_0000409 (denotator type)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000409 "A denotator type indicates how a term should be interpreted from an ontological perspective."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000409 "Alan Ruttenberg"@en)
