ObjectPropertyDomain(pbpko:OBI_0000299 pbpko:COB_0000035)

# Object Property: pbpko:OBI_0000312 (is specified output of)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000312 "A relation between a completely executed planned process and a continuant participating in that process. The presence of the continuant at the end of the process is explicitly specified in the objective specification which the process realizes the concretization of."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000312 "Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000312 "PERSON:Bjoern Peters")
AnnotationAssertion(rdfs:label pbpko:OBI_0000312 "is specified output of"@en)
SubObjectPropertyOf(pbpko:OBI_0000312 pbpko:RO_0000056)
ObjectPropertyRange(pbpko:OBI_0000312 pbpko:COB_0000035)

# Object Property: pbpko:OBI_0000417 (achieves_planned_objective)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000417 "This relation obtains between a planned process and a objective specification when the criteria specified in the objective specification are met at the end of the planned process."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000417 "BP, AR, PPPB branch")
AnnotationAssertion(rdfs:label pbpko:OBI_0000417 "achieves_planned_objective")
InverseObjectProperties(pbpko:OBI_0000417 pbpko:OBI_0000833)
ObjectPropertyDomain(pbpko:OBI_0000417 pbpko:COB_0000035)
ObjectPropertyRange(pbpko:OBI_0000417 pbpko:IAO_0000005)

# Object Property: pbpko:OBI_0000833 (objective_achieved_by)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000833 "This relation obtains between an objective specification and a planned process when the criteria specified in the objective specification are met at the end of the planned process."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000833 "OBI")
AnnotationAssertion(rdfs:label pbpko:OBI_0000833 "objective_achieved_by")
ObjectPropertyDomain(pbpko:OBI_0000833 pbpko:IAO_0000005)
ObjectPropertyRange(pbpko:OBI_0000833 pbpko:COB_0000035)

# Object Property: pbpko:RO_0000052 (characteristic of)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000052 "a relation between a specifically dependent continuant (the characteristic) and any other entity (the bearer), in which the characteristic depends on the bearer for its existence."@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000052 "characteristic of"@en)

# Object Property: pbpko:RO_0000056 (participates in)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000056 "a relation between a continuant and a process, in which the continuant is somehow involved in the process"@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000056 "participates in"@en)

# Object Property: pbpko:RO_0000057 (has participant)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000057 "a relation between a process and a continuant, in which the continuant is somehow involved in the process"@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000057 "has participant"@en)

# Object Property: pbpko:RO_0000059 (concretizes)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000059 "A relationship between a specifically dependent continuant and a generically dependent continuant, in which the generically dependent continuant depends on some independent continuant in virtue of the fact that the specifically dependent continuant also depends on that same independent continuant. Multiple specifically dependent continuants can concretize the same generically dependent continuant."@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000059 "concretizes"@en)

# Object Property: pbpko:RO_0000087 (has role)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000087 "a relation between an independent continuant (the bearer) and a role, in which the role specifically depends on the bearer for its existence"@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000087 "has role"@en)

# Object Property: pbpko:RO_0002351 (has member)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0002351 "has member is a mereological relation between a collection and an item.")
AnnotationAssertion(rdfs:label pbpko:RO_0002351 "has member"@en)
IrreflexiveObjectProperty(pbpko:RO_0002351)



