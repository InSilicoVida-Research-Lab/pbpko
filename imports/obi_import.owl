AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0002236 "Chris Stoeckert, Helena Ellis")
AnnotationAssertion(rdfs:label pbpko:OBI_0002236 "pT1a (lung)")
ClassAssertion(pbpko:OBI_0002232 pbpko:OBI_0002236)

