# Object Property: pbpko:OBI_0000295 (is specified input of)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000295 "A relation between a completely executed planned process and a continuant participating in that process that is not created during the process. The presence of the continuant during the process is explicitly specified in the plan specification which the process realizes the concretization of.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000295 "Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000295 "PERSON:Bjoern Peters")
AnnotationAssertion(rdfs:label pbpko:OBI_0000295 "is specified input of"@en)
SubObjectPropertyOf(pbpko:OBI_0000295 pbpko:RO_0000056)
ObjectPropertyRange(pbpko:OBI_0000295 pbpko:COB_0000035)

# Object Property: pbpko:OBI_0000299 (has specified output)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000299 "The inverse property of is specified output of")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000299 "PERSON: Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000299 "PERSON: Bjoern Peters")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000299 "PERSON: Larry Hunter")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000299 "PERSON: Melanie Courtot")
