AnnotationAssertion(rdfs:label pbpko:OBI_0002252 "pT3a (kidney)")
ClassAssertion(pbpko:OBI_0002243 pbpko:OBI_0002252)

# Individual: pbpko:OBI_0002253 (pT3b (kidney))

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0002253 "A pathologic primary tumor stage for kidney according to AJCC 7th edition indicating that the tumor grossly extends into vena cava below diaphragm."@en)
