# Individual: pbpko:OBI_0002212 (G2 (Fuhrman))

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0002212 "A histologic grade according to the Fuhrman Nuclear Grading System indicating that nuclei are slightly irregular, approximately 15um and nucleoli are evident."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0002212 "Chris Stoeckert, Helena Ellis")
AnnotationAssertion(rdfs:label pbpko:OBI_0002212 "G2 (Fuhrman)")
ClassAssertion(pbpko:OBI_0002210 pbpko:OBI_0002212)

# Individual: pbpko:OBI_0002213 (G3 (Fuhrman))

