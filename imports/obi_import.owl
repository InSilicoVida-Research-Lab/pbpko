AnnotationAssertion(pbpko:IAO_0000115 pbpko:BFO_0000050 "a core relation that holds between a part and its whole"@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000050 "part of")
AnnotationAssertion(rdfs:label pbpko:BFO_0000050 "part of"@en)
