AnnotationAssertion(rdfs:label pbpko:BFO_0000023 "role"@en)
SubClassOf(pbpko:BFO_0000023 pbpko:BFO_0000017)

# Class: pbpko:BFO_0000040 (material entity)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:BFO_0000040 "An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time."@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000040 "material entity"@en)

# Class: pbpko:BFO_0000141 (immaterial entity)

AnnotationAssertion(rdfs:label pbpko:BFO_0000141 "immaterial entity"@en)

# Class: pbpko:CHEBI_16670 (peptide)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:CHEBI_16670 "Amide derived from two or more amino carboxylic acid molecules (the same or different) by formation of a covalent bond from the carbonyl carbon of one to the nitrogen atom of another with formal loss of water. The term is usually applied to structures formed from α-amino acids, but it includes those derived from any amino carboxylic acid. X = OH, OR, NH2, NHR, etc.")
AnnotationAssertion(rdfs:label pbpko:CHEBI_16670 "peptide")
SubClassOf(pbpko:CHEBI_16670 pbpko:CHEBI_33839)

# Class: pbpko:CHEBI_24636 (proton)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:CHEBI_24636 "Nuclear particle of charge number +1, spin 1/2 and rest mass of 1.007276470(12) u.")
AnnotationAssertion(pbpko:IAO_0000115 pbpko:CHEBI_24636 "Nuclear particle of charge number +1, spin ½ and rest mass of 1.007276470(12) u.")
AnnotationAssertion(rdfs:label pbpko:CHEBI_24636 "proton")
SubClassOf(pbpko:CHEBI_24636 pbpko:CHEBI_36342)
SubClassOf(pbpko:CHEBI_24636 pbpko:COB_0000013)

# Class: pbpko:CHEBI_33252 (atomic nucleus)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:CHEBI_33252 "A nucleus is the positively charged central portion of an atom, excluding the orbital electrons.")
AnnotationAssertion(rdfs:label pbpko:CHEBI_33252 "atomic nucleus")
SubClassOf(pbpko:CHEBI_33252 pbpko:CHEBI_36342)
SubClassOf(pbpko:CHEBI_33252 ObjectSomeValuesFrom(pbpko:BFO_0000051 pbpko:CHEBI_24636))

# Class: pbpko:CHEBI_33839 (macromolecule)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:CHEBI_33839 "A macromolecule is a molecule of high relative molecular mass, the structure of which essentially comprises the multiple repetition of units derived, actually or conceptually, from molecules of low relative molecular mass.")
AnnotationAssertion(rdfs:label pbpko:CHEBI_33839 "macromolecule")
SubClassOf(pbpko:CHEBI_33839 pbpko:COB_0000013)

# Class: pbpko:CHEBI_36342 (subatomic particle)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:CHEBI_36342 "A particle smaller than an atom.")
AnnotationAssertion(rdfs:label pbpko:CHEBI_36342 "subatomic particle")
SubClassOf(pbpko:CHEBI_36342 pbpko:BFO_0000040)
DisjointClasses(pbpko:CHEBI_36342 pbpko:COB_0000011)

# Class: pbpko:CL_0000000 (cell)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:CL_0000000 "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane.")
AnnotationAssertion(rdfs:label pbpko:CL_0000000 "cell")
SubClassOf(pbpko:CL_0000000 pbpko:UBERON_0000465)

# Class: pbpko:COB_0000011 (atom)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:COB_0000011 "A material entity consisting of exactly one atomic nucleus and the electron(s) orbiting it."@en)
AnnotationAssertion(rdfs:label pbpko:COB_0000011 "atom"@en)
SubClassOf(pbpko:COB_0000011 pbpko:BFO_0000040)
SubClassOf(pbpko:COB_0000011 ObjectSomeValuesFrom(pbpko:BFO_0000051 pbpko:CHEBI_33252))
DisjointClasses(pbpko:COB_0000011 pbpko:COB_0000013)

# Class: pbpko:COB_0000013 (molecule)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:COB_0000013 "A material entity that consists of two or more atoms that are all connected via covalent bonds such that any atom can be transitively connected with any other atom."@en)
AnnotationAssertion(rdfs:label pbpko:COB_0000013 "molecule"@en)
SubClassOf(pbpko:COB_0000013 pbpko:BFO_0000040)
SubClassOf(pbpko:COB_0000013 ObjectSomeValuesFrom(pbpko:BFO_0000051 pbpko:COB_0000011))

# Class: pbpko:COB_0000021 (gross anatomical part)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:COB_0000021 "A part of a multicellular organism that is a collection of cell components that are not all contained in one cell."@en)
AnnotationAssertion(rdfs:label pbpko:COB_0000021 "gross anatomical part"@en)
SubClassOf(pbpko:COB_0000021 pbpko:UBERON_0000465)

# Class: pbpko:COB_0000022 (organism)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:COB_0000022 "A material entity that is a maximal functionally integrated unit that develops from a program encoded in a genome"@en)
AnnotationAssertion(rdfs:label pbpko:COB_0000022 "organism"@en)
SubClassOf(pbpko:COB_0000022 pbpko:UBERON_0000465)

# Class: pbpko:COB_0000035 (completely executed planned process)

AnnotationAssertion(rdfs:label pbpko:COB_0000035 "completely executed planned process"@en)
SubClassOf(pbpko:COB_0000035 pbpko:COB_0000082)
SubClassOf(pbpko:COB_0000035 ObjectSomeValuesFrom(pbpko:BFO_0000055 pbpko:OBI_0000260))
DisjointClasses(pbpko:COB_0000035 pbpko:GO_0008150)

# Class: pbpko:COB_0000080 (complex of molecules)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:COB_0000080 "A complex of two or more molecules that are not covalently bound."@en)
AnnotationAssertion(rdfs:label pbpko:COB_0000080 "complex of molecules"@en)
SubClassOf(pbpko:COB_0000080 pbpko:BFO_0000040)
SubClassOf(pbpko:COB_0000080 ObjectSomeValuesFrom(pbpko:BFO_0000051 pbpko:COB_0000013))

# Class: pbpko:COB_0000082 (planned process)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:COB_0000082 "A process that is initiated by an agent who intends to carry out a plan to achieve an objective through one or more actions as described in a plan specification."@en)
AnnotationAssertion(rdfs:label pbpko:COB_0000082 "planned process"@en)
SubClassOf(pbpko:COB_0000082 pbpko:BFO_0000015)

# Class: pbpko:COB_0000502 (characteristic)

AnnotationAssertion(rdfs:label pbpko:COB_0000502 "characteristic"@en)

# Class: pbpko:GO_0003674 (molecular_function)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:GO_0003674 "A molecular process that can be carried out by the action of a single macromolecular machine, usually via direct physical interactions with other molecular entities. Function in this sense denotes an action, or activity, that a gene product (or a complex) performs.")
AnnotationAssertion(rdfs:label pbpko:GO_0003674 "gene product or complex activity"@en)
AnnotationAssertion(rdfs:label pbpko:GO_0003674 "molecular_function")
SubClassOf(pbpko:GO_0003674 pbpko:BFO_0000015)

# Class: pbpko:GO_0005575 (cellular_component)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:GO_0005575 "A location, relative to cellular compartments and structures, occupied by a macromolecular machine. There are three types of cellular components described in the gene ontology: (1) the cellular anatomical entity where a gene product carries out a molecular function (e.g., plasma membrane, cytoskeleton) or membrane-enclosed compartments (e.g., mitochondrion); (2) virion components, where viral proteins act, and (3) the stable macromolecular complexes of which gene product are parts (e.g., the clathrin complex).")
AnnotationAssertion(rdfs:label pbpko:GO_0005575 "cellular_component")
EquivalentClasses(pbpko:GO_0005575 ObjectUnionOf(pbpko:GO_0032991 pbpko:GO_0044423 pbpko:GO_0110165))
SubClassOf(pbpko:GO_0005575 pbpko:BFO_0000040)

# Class: pbpko:GO_0008150 (biological_process)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:GO_0008150 "A biological process is the execution of a genetically-encoded biological module or program. It consists of all the steps required to achieve the specific biological objective of the module. A biological process is accomplished by a particular set of molecular functions carried out by specific gene products (or macromolecular complexes), often in a highly regulated manner and in a particular temporal sequence.")
AnnotationAssertion(rdfs:label pbpko:GO_0008150 "biological process"@en)
AnnotationAssertion(rdfs:label pbpko:GO_0008150 "biological_process")
SubClassOf(pbpko:GO_0008150 pbpko:BFO_0000015)
SubClassOf(pbpko:GO_0008150 ObjectSomeValuesFrom(pbpko:BFO_0000051 pbpko:GO_0003674))

# Class: pbpko:GO_0032991 (protein-containing complex)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:GO_0032991 "A stable assembly of two or more macromolecules, i.e. proteins, nucleic acids, carbohydrates or lipids, in which at least one component is a protein and the constituent parts function together.")
AnnotationAssertion(rdfs:label pbpko:GO_0032991 "protein-containing complex")
SubClassOf(pbpko:GO_0032991 pbpko:COB_0000080)
SubClassOf(pbpko:GO_0032991 pbpko:GO_0005575)
SubClassOf(pbpko:GO_0032991 ObjectSomeValuesFrom(pbpko:BFO_0000051 pbpko:PR_000000001))

# Class: pbpko:GO_0044423 (virion component)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:GO_0044423 "Any constituent part of a virion, a complete fully infectious extracellular virus particle.")
AnnotationAssertion(rdfs:label pbpko:GO_0044423 "virion component")
SubClassOf(pbpko:GO_0044423 pbpko:GO_0005575)

# Class: pbpko:GO_0110165 (cellular anatomical entity)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:GO_0110165 "A part of a cellular organism that is either an immaterial entity or a material entity with granularity above the level of a protein complex but below that of an anatomical system. Or, a substance produced by a cellular organism with granularity above the level of a protein complex.")
AnnotationAssertion(rdfs:label pbpko:GO_0110165 "cellular anatomical entity")
SubClassOf(pbpko:GO_0110165 pbpko:GO_0005575)
SubClassOf(pbpko:GO_0110165 pbpko:UBERON_0000465)
SubClassOf(pbpko:GO_0110165 ObjectSomeValuesFrom(pbpko:BFO_0000051 pbpko:COB_0000013))

# Class: pbpko:IAO_0000003 (measurement unit label)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000003 "A measurement unit label is as a label that is part of a scalar measurement datum and denotes a unit of measure."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000003 "measurement unit label"@en)
SubClassOf(pbpko:IAO_0000003 pbpko:IAO_0000009)

# Class: pbpko:IAO_0000005 (objective specification)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000005 "A directive information entity that describes an intended process endpoint. When part of a plan specification the concretization is realized in a planned process in which the bearer tries to effect the world so that the process endpoint is achieved."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000005 "objective specification"@en)
SubClassOf(pbpko:IAO_0000005 pbpko:IAO_0000033)

# Class: pbpko:IAO_0000009 (datum label)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000009 "A label is a symbol that is part of some other datum and is used to either partially define  the denotation of that datum or to provide a means for identifying the datum as a member of the set of data with the same label"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000009 "datum label"@en)
SubClassOf(pbpko:IAO_0000009 pbpko:IAO_0000030)

# Class: pbpko:IAO_0000010 (software)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000010 "Software is a plan specification composed of a series of instructions that can be 
interpreted by or directly executed by a processing unit."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000010 "software"@en)
SubClassOf(pbpko:IAO_0000010 pbpko:IAO_0000104)

# Class: pbpko:IAO_0000027 (data entity)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000027 "An information content entity that is intended to be a truthful statement about something (modulo, e.g., measurement precision or other systematic errors) and is constructed/acquired by a method which reliably tends to produce (approximately) truthful statements."@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000027 "An information content entity that is intended to be one or more truthful statement(s) about something (modulo, e.g., measurement precision or other systematic errors) and is constructed/acquired by a method which reliably tends to produce (approximately) truthful statements."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000027 "data entity"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000027 "data item"@en)
SubClassOf(pbpko:IAO_0000027 pbpko:IAO_0000030)

# Class: pbpko:IAO_0000030 (information content entity)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000030 "A generically dependent continuant that is about some thing."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000030 "information content entity"@en)

# Class: pbpko:IAO_0000033 (directive information entity)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000033 "An information content entity whose concretizations indicate to their bearer how to realize them in a process."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000033 "directive information entity"@en)
SubClassOf(pbpko:IAO_0000033 pbpko:IAO_0000030)

# Class: pbpko:IAO_0000037 (dot plot)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000037 "A dot plot is a report graph which is a graphical representation of data where each data point is represented by a single dot placed on coordinates corresponding to data point values in particular dimensions."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000037 "dot plot"@en)
SubClassOf(pbpko:IAO_0000037 pbpko:IAO_0000038)

# Class: pbpko:IAO_0000038 (graph)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000038 "A diagram that presents one or more tuples of information by mapping those tuples in to a two dimensional space in a non arbitrary way."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000038 "graph"@en)
SubClassOf(pbpko:IAO_0000038 pbpko:IAO_0000308)

# Class: pbpko:IAO_0000064 (algorithm)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000064 "A plan specification which describes the inputs and output of mathematical functions as well as workflow of execution for achieving an predefined objective. Algorithms are realized usually by means of implementation as computer programs for execution by automata."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000064 "algorithm"@en)
SubClassOf(pbpko:IAO_0000064 pbpko:IAO_0000104)

# Class: pbpko:IAO_0000078 (curation status specification)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000078 "The curation status of the term. The allowed values come from an enumerated list of predefined terms. See the specification of these instances for more detailed definitions of each enumerated value."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000078 "PERSON:Bill Bug"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000078 "curation status specification"@en)
