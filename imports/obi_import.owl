AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Helen Parkinson"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "James Malone"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Melanie Courtot"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Philippe Rocca-Serra")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Richard Scheuermann"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Ryan Brinkman"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Tina Hernandez-Boussard"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0200000 "data transformation"@en)
