    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00236">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the rate constant for elimination via fecal excretion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>fecal elimination rate constant</rdfs:label>
    </owl:Class>
    


