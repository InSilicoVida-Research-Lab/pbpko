        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing individuals typically below fifteen years of age.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>pediatric lifestage</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00343 -->

