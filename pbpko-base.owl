    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00249 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00249">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure via the nasal passages.</pbpko:IAO_0000115>
