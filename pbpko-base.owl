        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving continuous administration directly into a vein over time.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>IVI</oboInOwl:hasSynonymType>
        <rdfs:label>intravenous infusion exposure</rdfs:label>
    </owl:Class>
    


