        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008152"/>
        <pbpko:IAO_0000115>A metabolism process involving the conjugation of phase I products (or parent compounds) to hydrophilic moieties to facilitate excretion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <rdfs:label>phase II</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00209 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00209">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008152"/>
        <pbpko:IAO_0000115>A metabolism/transport process involving the further processing and excretion of conjugated metabolites (often involving efflux transporters).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>phase III</rdfs:label>
    </owl:Class>
    


