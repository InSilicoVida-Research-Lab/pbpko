        <pbpko:IAO_0000115>A biochemical parameter representing the rate constant for elimination via renal (urinary) excretion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>renal elimination rate constant</rdfs:label>
    </owl:Class>
    


