        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>tmax</oboInOwl:hasSynonymType>
        <rdfs:label>maximum time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00256 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00256">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the integral of the concentration-time curve (AUC), indicating total exposure.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>AUC</oboInOwl:hasSynonymType>
        <rdfs:label>area under curve</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00257 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00257">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00256"/>
        <pbpko:IAO_0000115>An area under curve parameter calculated from time zero to a specific time point t (AUC0-t).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>auc 0 to t</oboInOwl:hasSynonymType>
        <rdfs:label>area under curve 0 to t</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00258 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00258">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00256"/>
        <pbpko:IAO_0000115>An area under curve parameter calculated from time zero to the time of the last measurable concentration (AUClast).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>auclast</oboInOwl:hasSynonymType>
        <rdfs:label>area under curve last</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00259 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00259">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00256"/>
        <pbpko:IAO_0000115>An area under curve parameter extrapolated from time zero to infinity (AUC0-inf), representing total exposure after a single dose.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>auc 0 infinity</oboInOwl:hasSynonymType>
        <rdfs:label>area under curve 0 to infinity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00260 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00260">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter calculated as the integral of the product of time and concentration versus time (AUMC).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>aumc</oboInOwl:hasSynonymType>
        <rdfs:label>area under moment curve</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00261 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00261">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the average time a compound resides in the body (MRT).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>MRT</oboInOwl:hasSynonymType>
        <rdfs:label>mean residence time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00262 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00262">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the time required for the compound concentration to decrease by half (t1/2).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>t1/2</oboInOwl:hasSynonymType>
        <rdfs:label>half-life</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00263 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00263">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the rate and extent to which an active compound is absorbed and becomes available at the site of action or systemic circulation.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>f</oboInOwl:hasSynonymType>
        <rdfs:label>bioavailability</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00264 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00264">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00263"/>
        <pbpko:IAO_0000115>A bioavailability parameter comparing the rate and extent of absorption of a test compound to a reference compound.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>frel</oboInOwl:hasSynonymType>
        <rdfs:label>relative bioavailability</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00265 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00265">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the average time for a compound to be absorbed into systemic circulation (MAT).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>MAT</oboInOwl:hasSynonymType>
        <rdfs:label>mean absorption time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00266 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00266">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the average time for a compound to dissolve in the body (MDT).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>MDT</oboInOwl:hasSynonymType>
        <rdfs:label>mean dissolution time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00267 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00267">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter indicating comparable bioavailability between test and reference formulations under similar conditions.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>be</oboInOwl:hasSynonymType>
        <rdfs:label>bioequivalence</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00268 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00268">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00263"/>
        <pbpko:IAO_0000115>A bioavailability parameter comparing the amount reaching systemic circulation after non-IV administration to the amount available after IV administration.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>fabs</oboInOwl:hasSynonymType>
        <rdfs:label>absolute bioavailability</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00269 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00269">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00322"/>
        <pbpko:IAO_0000115>An elimination process phase describing the period where removal of the compound from the body predominates.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>elimination phase</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00270 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00270">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00140"/>
        <pbpko:IAO_0000115>An absorption process phase describing the period where the compound moves from the administration site into systemic circulation.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>absorption phase</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00272 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00272">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00615"/>
        <pbpko:IAO_0000115>The amount of compound in the urine compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>aurine</oboInOwl:hasSynonymType>
        <rdfs:label>amount in urine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00273 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00273">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00615"/>
        <pbpko:IAO_0000115>The amount of compound in the feces compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>afeces</oboInOwl:hasSynonymType>
        <rdfs:label>amount in feces</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00274 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00274">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the total amount of compound excreted in urine over a specific time period.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>cumulative amount in urine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00275 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00275">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the total amount of compound excreted in feces over a specific time period.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>cumulative amount in feces</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00277 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00277">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00256"/>
        <pbpko:IAO_0000115>An area under curve parameter calculated over a dosing interval at steady state (AUCss).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>aucss</oboInOwl:hasSynonymType>
        <rdfs:label>steady state area under curve</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00279 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00279">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the minimum concentration of a compound in a specific organ after exposure.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>min organ concentration</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00280 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00280">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the maximum concentration of a compound in a specific organ after exposure.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>max organ concentration</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00281 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00281">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the median concentration of a compound in a specific organ after exposure.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>median organ concentration</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00282 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00282">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00549"/>
        <pbpko:IAO_0000115>A plasma concentration parameter representing the 2.5th percentile of the plasma concentration distribution in a population simulation.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>percentile 2.5 cplasma</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00283 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00283">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00549"/>
        <pbpko:IAO_0000115>A plasma concentration parameter representing the 97.5th percentile of the plasma concentration distribution in a population simulation.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>percentile 97.5 cplasma</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00284 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00284">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter (or exposure limit) estimating the amount of a substance that can be ingested daily over a lifetime without appreciable health risk (TDI).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>tdi</oboInOwl:hasSynonymType>
        <rdfs:label>tolerable daily intake</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00285 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00285">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter estimating the amount of compound exposure based on internal body measurements.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>reconstructed exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00286 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00286">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter estimating the amount of a compound consumed daily (EDI).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>edi</oboInOwl:hasSynonymType>
        <rdfs:label>estimated daily intake</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00287 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00287">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the concentration of a chemical (or metabolite) in a biological medium consistent with exposure guidance values (BE).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>be</oboInOwl:hasSynonymType>
        <rdfs:label>biomonitoring equivalent</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00289 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00289">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter (or exposure limit) estimating the daily oral or dermal exposure likely to be without appreciable risk over a lifetime (RfD).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>RfD</oboInOwl:hasSynonymType>
        <rdfs:label>reference dose</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00290 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00290">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter (or exposure limit) estimating the amount of a substance in food/water that can be consumed daily without appreciable health risk (ADI).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>adi</oboInOwl:hasSynonymType>
        <rdfs:label>acceptable daily intake</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00296 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00296">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000100"/>
        <pbpko:IAO_0000115>A data set containing the physiological parameters representing a standard human, often defined by specific characteristics like 70 kg body weight.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>reference human data set</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00297 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00297">
