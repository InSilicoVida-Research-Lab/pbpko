        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vgut</oboInOwl:hasSynonymType>
        <rdfs:label>volume of gut</rdfs:label>
    </owl:Class>
    


