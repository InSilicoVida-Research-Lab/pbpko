    <!-- http://purl.obolibrary.org/obo/PBPKO_00002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <pbpko:IAO_0000115>A data item involved in PBPK modelling.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>parameter</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000658"/>
        <pbpko:IAO_0000115>A data representation model that predicts the absorption, distribution, metabolism, and excretion (ADME) of chemical substances in biological species based on physiological principles using mathematical modelling technique.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>PBPK</oboInOwl:hasSynonymType>
        <rdfs:label>physiologically based pharmacokinetic model</rdfs:label>
    </owl:Class>
    


