    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00528">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00012"/>
        <pbpko:IAO_0000115>A blood flow rate parameter representing the cardiac output specifically related to plasma flow.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>qcplasma</oboInOwl:hasSynonymType>
        <rdfs:label>cardiac output rate of plasma</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00529 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00529">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00012"/>
        <pbpko:IAO_0000115>A blood flow rate parameter specifically describing the rate to the filtrate compartment (representing glomerular filtration).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>qfiltrate</oboInOwl:hasSynonymType>
        <rdfs:label>blood flow rate to filtrate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00530 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00530">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00012"/>
        <pbpko:IAO_0000115>A blood flow parameter specifically describing the rate to the bone marrow compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>qbm</oboInOwl:hasSynonymType>
        <rdfs:label>blood flow rate to bone marrow</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00531 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00531">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00012"/>
        <pbpko:IAO_0000115>A blood flow rate parameter specifically describing the rate to the gut compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>qgut</oboInOwl:hasSynonymType>
        <rdfs:label>blood flow rate to gut</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00532 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00532">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00012"/>
        <pbpko:IAO_0000115>A blood flow rate parameter specifically describing the rate to the mammary gland compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>qmam</oboInOwl:hasSynonymType>
        <rdfs:label>blood flow rate to mammary gland</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00533 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00533">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00012"/>
        <pbpko:IAO_0000115>A blood flow rate parameter representing the check for total blood flow mass balance of all the compartments (sum of organ flows should equal cardiac output).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>qmassbal</oboInOwl:hasSynonymType>
        <rdfs:label>blood flow rate for mass balance</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00534 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00534">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the rate at which a compound is cleared via urine.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>kurine</oboInOwl:hasSynonymType>
        <rdfs:label>urinary rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00535 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00535">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter (Tm) representing the maximum rate of tubular resorption (e.g., in the kidney).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>tmc</oboInOwl:hasSynonymType>
        <rdfs:label>resorption maximum</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00536 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00536">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter or process representing the resorption of a compound (e.g., tubular resorption).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
