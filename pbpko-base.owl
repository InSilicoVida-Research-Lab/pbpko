    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00525">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00066"/>
        <pbpko:IAO_0000115>A volume parameter representing the total volume of the mammary gland compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vmam</oboInOwl:hasSynonymType>
        <rdfs:label>volume of mammary gland</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00526 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00526">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00066"/>
        <pbpko:IAO_0000115>A volume parameter representing the check for total mass balance of all compartments (sum of organ volumes should equal body volume/weight equivalent, depending on units).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vmass bal</oboInOwl:hasSynonymType>
        <rdfs:label>volume of mass balance</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00527 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00527">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00066"/>
        <pbpko:IAO_0000115>A volume parameter representing the total volume of red blood cells in whole blood.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vhct</oboInOwl:hasSynonymType>
        <rdfs:label>hematocrit volume</rdfs:label>
    </owl:Class>
    


