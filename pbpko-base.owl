        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>permeability limited pbpk</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00304 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00304">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00613"/>
        <pbpko:IAO_0000115>Maximum rate (Vmax) of transport via a basolateral transporter, measured in vitro.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vmax baso in vitro</oboInOwl:hasSynonymType>
        <rdfs:label>maximum rate of basolateral transporter in vitro</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00305 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00305">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>Michaelis constant representing the substrate concentration at half-maximal velocity (Km) for a basolateral transporter.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>km baso</oboInOwl:hasSynonymType>
        <rdfs:label>Michaelis constant baso</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00306 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00306">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00613"/>
        <pbpko:IAO_0000115>A maximum rate (Vmax) of an enzyme catalysed reaction for a compound across the apical membrane of an organ, measured in vitro, when the enzyme is saturated with substrate.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vmax apical in vitro</oboInOwl:hasSynonymType>
