        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving administration under the skin.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
