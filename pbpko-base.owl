        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>restbody plasma pc</oboInOwl:hasSynonymType>
        <rdfs:label>restbody plasma partition coefficient</rdfs:label>
