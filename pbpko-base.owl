    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00221 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00221">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter (kdeg) representing the rate constant for the degradation of a metabolizing enzyme or transporter.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>kdeg</oboInOwl:hasSynonymType>
        <rdfs:label>degradation rate constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00222 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00222">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter (Ki) representing the inhibition constant for a specific enzyme or transporter interaction.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>ki</oboInOwl:hasSynonymType>
        <rdfs:label>inhibition constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00223 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00223">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of compounds and metabolites primarily through urine via the kidneys.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>renal excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00224 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00224">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of compounds and metabolites via the liver (often into bile).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>hepatic excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00225 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00225">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of compounds and metabolites through feces.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>fecal excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00226 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00226">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of volatile compounds and metabolites through respiration.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>exhalation</rdfs:label>
        <skos:closeMatch>http://purl.bioontology.org/ontology/MESH/D045853</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00227 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00227">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of compounds and metabolites through sweat.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>sweat excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00228 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00228">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination and deposition of compounds and metabolites into hair.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>hair excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00229 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00229">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the volume of biological fluid cleared of a compound per unit time.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>cl</oboInOwl:hasSynonymType>
        <rdfs:label>clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00230 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00230">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via feces.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>fecal clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00231 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00231">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via sweat.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>sweat clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00232 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00232">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via urine.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>urinary clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00233 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00233">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via bile.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>biliary clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00234 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00234">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via the liver (metabolism and/or biliary excretion).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>hepatic clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00235 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00235">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate representing the inherent ability of an organ or tissue to eliminate a compound, independent of blood flow or binding.</pbpko:IAO_0000115>
