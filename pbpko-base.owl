    <!-- http://purl.obolibrary.org/obo/PBPKO_00310 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00310">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter (kin) describing the rate constant for compound movement into a cell or compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>kiff</oboInOwl:hasSynonymType>
