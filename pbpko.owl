        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0200000"/>
        <pbpko:IAO_0000115 xml:lang="en">A class prediction data transformation (sometimes called supervised classification) is a data transformation that has objective class prediction.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>James Malone</pbpko:IAO_0000117>
        <rdfs:label xml:lang="en">class prediction data transformation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000684 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000684">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000005"/>
        <pbpko:IAO_0000115 xml:lang="en">A objective specification that is fulfilled by obtaining a material entity for potential use as an input upon which measurements or observations are performed.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>Bjoern Peters</pbpko:IAO_0000117>
        <rdfs:label>specimen collection objective</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000700 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000700">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000663"/>
        <rdfs:subClassOf>
            <owl:Restriction>
