        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>kurine c</oboInOwl:hasSynonymType>
        <rdfs:label>urinary rate constant</rdfs:label>
    </owl:Class>
    


