        <pbpko:IAO_0000115>A volume parameter representing the total volume of lymph compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vlymph</oboInOwl:hasSynonymType>
        <rdfs:label>volume of lymph</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00120 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00120">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00610"/>
        <pbpko:IAO_0000115>A dimensionless fraction of volume defined as the lymph volume divided per unit of total body weight.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>flymph</oboInOwl:hasSynonymType>
        <rdfs:label>fraction of lymph</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00121 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00121">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00066"/>
        <pbpko:IAO_0000115>A volume parameter representing the total volume of the arterial compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>arterial volume</rdfs:label>
        <skos:closeMatch>http://purl.bioontology.org/ontology/LNC/LP430862-5</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00122 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00122">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00066"/>
        <pbpko:IAO_0000115>A volume parameter representing the total volume of the venous compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>venous volume</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00126 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00126">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00002"/>
        <pbpko:IAO_0000115>A parameter relating to the physical and chemical properties of a compound (e.g., MW, lipophilicity, solubility, pKa).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>physicochemical parameter</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00127 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00127">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the sum of the weights of all atoms in a molecule.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>MW</oboInOwl:hasSynonymType>
        <rdfs:label>molecular weight</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00128 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00128">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the affinity or tendency of a compound to dissolve in lipids or hydrophobic environments.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>lipophillicity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00129 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00129">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the logarithm of the ratio of concentrations of a compound in a mixture of two immiscible phases at equilibrium, specifically describing lipophilicity (LogD).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>Log D</oboInOwl:hasSynonymType>
        <rdfs:label>distribution coefficient</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00130 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00130">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the ratio of a dissolved compound in a two-phase system (often used interchangeably with partition coefficient).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>dissolution in two phase system</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00131 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00131">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the 10-based logarithm of a compound&apos;s solubility (typically in mol/L).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>log S</oboInOwl:hasSynonymType>
        <rdfs:label>logarithmic solubility</rdfs:label>
        <skos:closeMatch>http://purl.bioontology.org/ontology/MESH/D012995</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00132 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00132">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the solubility of a compound specifically in water.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>water solubility</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00133 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00133">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the negative base-10 logarithm (pKa) of the acid dissociation constant (Ka).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>pka</oboInOwl:hasSynonymType>
        <rdfs:label>acid dissociation constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00134 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00134">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the negative base-10 logarithm (pKb) of the base dissociation constant (Kb).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>pKb pK(b) pK(B) affinity constant, Base dissociation constant</oboInOwl:hasSynonymType>
        <rdfs:label>basic dissociation constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00135 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00135">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the electrical charge of a molecule at physiological pH.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>physiological charge</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00136 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00136">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the integer number of hydrogen bond acceptors in a molecular entity.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>A</oboInOwl:hasSynonymType>
        <rdfs:label>hydrogen acceptor count</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/CHEBI_13193</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00137 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00137">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the integer number of hydrogen bond donors in a molecular entity.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>hydrogen donor count</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/CHEBI_17499</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00138 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00138">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00126"/>
        <pbpko:IAO_0000115>A physicochemical parameter representing the integer count of rotatable bonds in a molecular entity.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>rotatable bond count</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00139 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00139">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00002"/>
        <pbpko:IAO_0000115>A parameter that is compound-dependent and relates to biological interactions or transformations (e.g., clearance, binding, partition coefficients).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>biochemical parameter</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00140 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00140">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
        <pbpko:IAO_0000115>A biological process by which a compound moves from its site of administration into the systemic circulation or a target tissue.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>A</oboInOwl:hasSynonymType>
        <rdfs:label>absorption</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/ExO_0000058</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00141 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00141">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_03075"/>
        <pbpko:IAO_0000115>An absorption rate constant parameter representing the rate constant for the movement of a compound from the gut to systemic circulation or another compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>Kac gut</oboInOwl:hasSynonymType>
        <rdfs:label>absorption rate constant gut</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00142 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00142">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_03075"/>
        <pbpko:IAO_0000115>An absorption rate constant parameter representing the movement of a compound from the intestine to systemic circulation or another compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>Kac intestine</oboInOwl:hasSynonymType>
        <rdfs:label>absorption rate constant intestine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00143 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00143">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the rate at which the stomach empties its contents into the small intestine.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>ge</oboInOwl:hasSynonymType>
        <rdfs:label>gastric emptying rate</rdfs:label>
        <skos:closeMatch>http://snomed.info/id/40117008</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00144 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00144">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
        <pbpko:IAO_0000115>A biological process involving recycling of compounds through the liver via biliary excretion, intestinal reabsorption, portal circulation return, and re-excretion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>EHR</oboInOwl:hasSynonymType>
        <rdfs:label>enterohepatic recirculation</rdfs:label>
        <skos:closeMatch>http://purl.bioontology.org/ontology/MESH/D004764</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00145 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00145">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the surface area-normalized transcellular permeability of the intestinal wall for a compound.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>specific intestinal permeability</rdfs:label>
        <skos:closeMatch>http://www.ebi.ac.uk/efo/EFO_0011031</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00146 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00146">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
        <pbpko:IAO_0000115>A biological process describing the movement of a compound from systemic circulation to various organs/tissues.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>distribution process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00147 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00147">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the apparent volume into which a compound distributes in the body relative to its plasma concentration.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>Vd</oboInOwl:hasSynonymType>
        <rdfs:label>volume of distribution</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00148 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00148">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00146"/>
        <pbpko:IAO_0000115>A distribution process (or molecular function) where substances bind to proteins or related compounds.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>protein binding mediated distributiion process</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/GO_0005515</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00149 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00149">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the fraction of a compound that is not bound (e.g., to proteins).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>FU</oboInOwl:hasSynonymType>
        <rdfs:label>unbound fraction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00150 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00150">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00149"/>
        <pbpko:IAO_0000115>An unbound fraction parameter specifically for the gut compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>fugut</oboInOwl:hasSynonymType>
        <rdfs:label>fraction unbound gut</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00151 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00151">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00149"/>
        <pbpko:IAO_0000115>An unbound fraction parameter specifically for the stomach compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>fustomach</oboInOwl:hasSynonymType>
        <rdfs:label>fraction unbound stomach</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00152 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00152">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00149"/>
        <pbpko:IAO_0000115>An unbound fraction parameter specifically for the intestine compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>fuintestine</oboInOwl:hasSynonymType>
        <rdfs:label>fraction unbound intestine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00153 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00153">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00149"/>
        <pbpko:IAO_0000115>An unbound fraction parameter specifically for the pancreas compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
