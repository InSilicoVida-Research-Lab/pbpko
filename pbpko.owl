        <pbpko:IAO_0000115 xml:lang="en">A pathologic distant metastases stage for kidney according to AJCC 7th edition indicating that there are distant metastases based on clinical assessment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>Chris Stoeckert, Helena Ellis</pbpko:IAO_0000117>
        <rdfs:label>cM1 (kidney)</rdfs:label>
