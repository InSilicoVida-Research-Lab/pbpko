                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10001"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10001"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00140"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10001"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00144"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10001"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00146"/>
            </owl:Restriction>
        </rdfs:subClassOf>
