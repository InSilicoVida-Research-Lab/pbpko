        <pbpko:IAO_0000115 xml:lang="en">A pathologic distant metastases stage for colon according to AJCC 7th edition indicating that metastasis is in more than one organ or the peritoneum and histologically confirmed.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>Chris Stoeckert, Helena Ellis</pbpko:IAO_0000117>
        <rdfs:label>pM1b (colon)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002299 -->

