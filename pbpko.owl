    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000749">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000707"/>
        <pbpko:IAO_0000115 xml:lang="en">A CART (classification and regression trees) is a data transformation method for producing a classification or regression model with a tree-based structure.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117 xml:lang="en">James Malone</pbpko:IAO_0000117>
        <rdfs:label xml:lang="en">CART</rdfs:label>
    </owl:Class>
    


