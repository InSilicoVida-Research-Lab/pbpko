        <pbpko:IAO_0000115 xml:lang="en">A pathologic distant metastases stage for lung according to AJCC 7th edition indicating that there is no distant metastasis.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>Chris Stoeckert, Helena Ellis</pbpko:IAO_0000117>
        <rdfs:label>cM0 (lung)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002300 -->

