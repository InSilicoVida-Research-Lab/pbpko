        </rdfs:subClassOf>
        <pbpko:IAO_0000115 xml:lang="en">A specimen that derives from an anatomical part or substance arising from an organism. Examples of tissue specimen include tissue, organ, physiological system, blood, or body location (arm).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>PERSON: Chris Stoeckert, Jie Zheng</pbpko:IAO_0000117>
        <rdfs:label>specimen from organism</rdfs:label>
    </owl:Class>
    


