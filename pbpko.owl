                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0200179"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <pbpko:IAO_0000115 xml:lang="en">A support vector machine is a data transformation with a class prediction objective based on the construction of a separating hyperplane that maximizes the margin between two data sets of vectors in n-dimensional space.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>James Malone</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>Ryan Brinkman</pbpko:IAO_0000117>
        <rdfs:label>support vector machine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000704 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000704">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0200166"/>
        <pbpko:IAO_0000115 xml:lang="en">A decision tree induction objective is a data transformation objective in which a tree-like graph of edges and nodes is created and from which the selection of each branch requires that some type of logical decision is made.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>James Malone</pbpko:IAO_0000117>
        <rdfs:label>decision tree induction objective</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000707 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000707">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000417"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000704"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0200000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000417"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000704"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <pbpko:IAO_0000115 xml:lang="en">A decision tree building data transformation is a data transformation that has objective decision tree induction.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>James Malone</pbpko:IAO_0000117>
        <rdfs:label xml:lang="en">decision tree building data transformation</rdfs:label>
    </owl:Class>
    


