        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>perfusion limited model</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00006 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00002"/>
        <pbpko:IAO_0000115>A parameter that provides the structural framework for a PBPK model and relates to the organism&apos;s physiology (e.g., body weight, organ volume, blood flow).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>physiological parameter</rdfs:label>
        <skos:closeMatch>http://snomed.info/id/398060001</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00006"/>
        <pbpko:IAO_0000115>A physiological parameter calculated as an individual&apos;s weight (kg) divided by the square of their height (m).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>BMI</oboInOwl:hasSynonymType>
        <rdfs:label>body mass index</rdfs:label>
        <skos:closeMatch>http://www.ebi.ac.uk/efo/EFO_0004340</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00008 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00006"/>
        <pbpko:IAO_0000115>A physiological parameter representing the mass or quantity of heaviness of an individual.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>bw</oboInOwl:hasSynonymType>
        <rdfs:label>bodyweight</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/CMO_0000012</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00009 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00006"/>
        <pbpko:IAO_0000115>A physiological parameter describing the distance from the bottom to the top of someone standing upright.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>ht</oboInOwl:hasSynonymType>
        <rdfs:label>height</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/PATO_0000119</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00006"/>
        <pbpko:IAO_0000115>A physiological parameter representing the total area that the surface of an object occupies.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
