        <pbpko:IAO_0000115>An output parameter (or exposure limit) estimating the amount of a substance that can be ingested daily over a lifetime without appreciable health risk (TDI).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>tdi</oboInOwl:hasSynonymType>
