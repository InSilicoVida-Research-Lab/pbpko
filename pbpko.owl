        <pbpko:IAO_0000115 xml:lang="en">A pathologic lymph node stage for kidney according to AJCC 7th edition indicating that there is no regional lymph node metastasis.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>Chris Stoeckert, Helena Ellis</pbpko:IAO_0000117>
        <rdfs:label>pN0 (kidney)</rdfs:label>
