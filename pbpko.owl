        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>HSA</oboInOwl:hasSynonymType>
        <rdfs:label>human serum albumin</rdfs:label>
        <skos:exactMatch>http://purl.bioontology.org/ontology/LNC/LP62267-7</skos:exactMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00187 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00187">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the ratio of compound concentration in whole blood to that in plasma.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>bp</oboInOwl:hasSynonymType>
        <rdfs:label>blood:plasma ratio</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00189 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00189">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter quantifying enzymatic reaction velocity (kcat), representing the maximum number of substrate molecules converted per active site per unit time.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>kcat</oboInOwl:hasSynonymType>
        <rdfs:label>catalytic rate constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00191 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00191">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008152"/>
        <pbpko:IAO_0000115>A metabolism process involving the conversion of exogenous substances to more polar metabolites, often via oxidation, reduction, or hydrolysis (e.g., by CYPs).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>phase I metabolism</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00200 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00200">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008152"/>
        <pbpko:IAO_0000115>A metabolism process involving the conjugation of phase I products (or parent compounds) to hydrophilic moieties to facilitate excretion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <rdfs:label>phase II</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00209 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00209">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008152"/>
        <pbpko:IAO_0000115>A metabolism/transport process involving the further processing and excretion of conjugated metabolites (often involving efflux transporters).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>phase III</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00210 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00210">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008152"/>
        <pbpko:IAO_0000115>A metabolism process occurring at a specific location (e.g., liver, gut wall) after administration but before reaching systemic circulation, reducing the concentration of active compound.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>first pass metabolism</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00211 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00211">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00613"/>
        <pbpko:IAO_0000115>A maximum rate (Vmax) of an enzyme catalysed reaction for a compound in the intestine when the enzyme is saturated with substrate.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vmax intestine</oboInOwl:hasSynonymType>
        <rdfs:label>maximum rate in intestine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00212 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00212">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>Michaelis constant representing the substrate concentration at which the reaction rate in the intestine is half of Vmax (Km).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>km intestine</oboInOwl:hasSynonymType>
        <rdfs:label>Michaelis constant  intestine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00213 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00213">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00613"/>
        <pbpko:IAO_0000115>A maximum rate (Vmax) of an enzyme catalysed reaction for a compound in the liver when the enzyme is saturated with substrate.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>vmax liver</oboInOwl:hasSynonymType>
        <rdfs:label>maximum rate in liver</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00214 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00214">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>Michaelis constant representing the substrate concentration at which the reaction rate in the liver is half of Vmax (Km).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>km liver</oboInOwl:hasSynonymType>
        <rdfs:label>Michaelis constant  liver</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00215 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00215">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008152"/>
        <pbpko:IAO_0000115>A metabolism process specifically occurring within the gut.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>gut metabolism</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00216 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00216">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter (Kd) measuring the affinity of a compound for its binding partner (e.g., receptor, protein).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>kd</oboInOwl:hasSynonymType>
        <rdfs:label>dissociation constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00217 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00217">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <pbpko:IAO_0000115>A material entity representing protein responsible for the import or export of compounds across cell membranes.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>transporter</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/TXPO_0003638</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00218 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00218">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00217"/>
        <pbpko:IAO_0000115>A transporter family (Organic Anion Transporting Polypeptides) involved in transporting organic anions.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>oatp</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/TXPO_0000272</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00219 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00219">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00217"/>
        <pbpko:IAO_0000115>A transporter (ATP-binding cassette subfamily C member 3) involved in bile metabolism and transport.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>abcc3</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/OGG_3000008714</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00220 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00220">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00217"/>
        <pbpko:IAO_0000115>A transporter (ATP-binding cassette subfamily C member 2) involved in transporting various molecules across cell membranes.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>abcc2</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/OGG_3000001244</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00221 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00221">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter (kdeg) representing the rate constant for the degradation of a metabolizing enzyme or transporter.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>kdeg</oboInOwl:hasSynonymType>
        <rdfs:label>degradation rate constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00222 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00222">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter (Ki) representing the inhibition constant for a specific enzyme or transporter interaction.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>ki</oboInOwl:hasSynonymType>
        <rdfs:label>inhibition constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00223 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00223">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of compounds and metabolites primarily through urine via the kidneys.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>renal excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00224 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00224">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of compounds and metabolites via the liver (often into bile).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>hepatic excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00225 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00225">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of compounds and metabolites through feces.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>fecal excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00226 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00226">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of volatile compounds and metabolites through respiration.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>exhalation</rdfs:label>
        <skos:closeMatch>http://purl.bioontology.org/ontology/MESH/D045853</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00227 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00227">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination of compounds and metabolites through sweat.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>sweat excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00228 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00228">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007588"/>
        <pbpko:IAO_0000115>An excretion process involving the elimination and deposition of compounds and metabolites into hair.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>hair excretion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00229 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00229">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the volume of biological fluid cleared of a compound per unit time.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>cl</oboInOwl:hasSynonymType>
        <rdfs:label>clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00230 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00230">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via feces.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>fecal clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00231 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00231">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via sweat.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>sweat clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00232 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00232">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via urine.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>urinary clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00233 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00233">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via bile.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>biliary clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00234 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00234">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate specifically quantifying elimination via the liver (metabolism and/or biliary excretion).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>hepatic clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00235 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00235">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00229"/>
        <pbpko:IAO_0000115>A clearance rate representing the inherent ability of an organ or tissue to eliminate a compound, independent of blood flow or binding.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>clint</oboInOwl:hasSynonymType>
        <rdfs:label>intrinsic clearance rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00236 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00236">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the rate constant for elimination via fecal excretion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>fecal elimination rate constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00237 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00237">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00139"/>
        <pbpko:IAO_0000115>A biochemical parameter representing the rate constant for elimination via renal (urinary) excretion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>renal elimination rate constant</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00238 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00238">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00322"/>
        <pbpko:IAO_0000115>An elimination process involving the irreversible transfer of compound or metabolites from plasma to bile via hepatocytes.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>biliary elimination</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00239 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00239">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00002"/>
        <pbpko:IAO_0000115>A parameter designating the body part or method through which exposure is introduced.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>route of exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00240 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00240">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure via the mouth.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>oral exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00241 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00241">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure via the skin.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>dermal exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00242 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00242">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure via inhalation into the lungs.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>inhalation exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00243 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00243">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving rapid injection directly into a vein.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>IVB</oboInOwl:hasSynonymType>
        <rdfs:label>intravenous bolus exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00244 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00244">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving continuous administration directly into a vein over time.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>IVI</oboInOwl:hasSynonymType>
        <rdfs:label>intravenous infusion exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00245 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00245">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving injection into a muscle.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>intramuscular exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00246 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00246">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving administration directly into an artery.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>intraarterial exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00247 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00247">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving administration into the spinal canal.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>intrathecal exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00248 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00248">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving administration under the skin.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>subcutaneous exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00249 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00249">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure via the nasal passages.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>nasal exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00250 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00250">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure involving absorption through the skin, typically from a patch.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>transdermal exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00251 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00251">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00239"/>
        <pbpko:IAO_0000115>A route of exposure via the eye.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>ocular exposure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00252 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00252">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00002"/>
        <pbpko:IAO_0000115>A parameter representing a result or prediction generated by the PBPK model.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>output parameter</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00253 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00253">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the highest concentration (Cmax) of a compound achieved after exposure.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>Cmax</oboInOwl:hasSynonymType>
        <rdfs:label>peak concentration</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00254 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00254">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the maximum concentration (Cmax,ss) achieved at steady state during repeated dosing.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>cmaxss</oboInOwl:hasSynonymType>
        <rdfs:label>maximum steady state concentration</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00255 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00255">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the time (Tmax) required to reach the peak concentration.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>tmax</oboInOwl:hasSynonymType>
        <rdfs:label>maximum time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00256 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00256">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the integral of the concentration-time curve (AUC), indicating total exposure.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>AUC</oboInOwl:hasSynonymType>
        <rdfs:label>area under curve</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00257 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00257">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00256"/>
        <pbpko:IAO_0000115>An area under curve parameter calculated from time zero to a specific time point t (AUC0-t).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>auc 0 to t</oboInOwl:hasSynonymType>
        <rdfs:label>area under curve 0 to t</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00258 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00258">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00256"/>
        <pbpko:IAO_0000115>An area under curve parameter calculated from time zero to the time of the last measurable concentration (AUClast).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>auclast</oboInOwl:hasSynonymType>
        <rdfs:label>area under curve last</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00259 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00259">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00256"/>
        <pbpko:IAO_0000115>An area under curve parameter extrapolated from time zero to infinity (AUC0-inf), representing total exposure after a single dose.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>auc 0 infinity</oboInOwl:hasSynonymType>
        <rdfs:label>area under curve 0 to infinity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00260 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00260">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter calculated as the integral of the product of time and concentration versus time (AUMC).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>aumc</oboInOwl:hasSynonymType>
        <rdfs:label>area under moment curve</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00261 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00261">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the average time a compound resides in the body (MRT).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>MRT</oboInOwl:hasSynonymType>
        <rdfs:label>mean residence time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00262 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00262">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the time required for the compound concentration to decrease by half (t1/2).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>t1/2</oboInOwl:hasSynonymType>
        <rdfs:label>half-life</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00263 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00263">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the rate and extent to which an active compound is absorbed and becomes available at the site of action or systemic circulation.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>f</oboInOwl:hasSynonymType>
        <rdfs:label>bioavailability</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00264 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00264">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00263"/>
        <pbpko:IAO_0000115>A bioavailability parameter comparing the rate and extent of absorption of a test compound to a reference compound.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>frel</oboInOwl:hasSynonymType>
        <rdfs:label>relative bioavailability</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00265 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00265">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the average time for a compound to be absorbed into systemic circulation (MAT).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>MAT</oboInOwl:hasSynonymType>
        <rdfs:label>mean absorption time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00266 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00266">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter representing the average time for a compound to dissolve in the body (MDT).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>MDT</oboInOwl:hasSynonymType>
        <rdfs:label>mean dissolution time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00267 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00267">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00252"/>
        <pbpko:IAO_0000115>An output parameter indicating comparable bioavailability between test and reference formulations under similar conditions.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>be</oboInOwl:hasSynonymType>
        <rdfs:label>bioequivalence</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00268 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00268">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00263"/>
        <pbpko:IAO_0000115>A bioavailability parameter comparing the amount reaching systemic circulation after non-IV administration to the amount available after IV administration.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>fabs</oboInOwl:hasSynonymType>
        <rdfs:label>absolute bioavailability</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00269 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00269">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00322"/>
        <pbpko:IAO_0000115>An elimination process phase describing the period where removal of the compound from the body predominates.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>elimination phase</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00270 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00270">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00140"/>
        <pbpko:IAO_0000115>An absorption process phase describing the period where the compound moves from the administration site into systemic circulation.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>absorption phase</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00272 -->

