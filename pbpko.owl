        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0200000"/>
        <pbpko:IAO_0000115 xml:lang="en">Peak matching is a data transformation performed on a dataset of a graph of ordered data points (e.g. a spectrum) with the objective of pattern matching local maxima above a noise threshold</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>James Malone</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>Ryan Brinkman</pbpko:IAO_0000117>
        <rdfs:label>peak matching</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000727 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000727">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0200171"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0200175"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000648"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000417"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0200178"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <pbpko:IAO_0000115 xml:lang="en">A k-nearest neighbors is a data transformation which achieves a class discovery or partitioning objective, in which an input data object with vector y is assigned to a class label based upon the k closest training data set points to y; where k is the largest value that class label is assigned.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117 xml:lang="en">James Malone</pbpko:IAO_0000117>
        <rdfs:label xml:lang="en">k-nearest neighbors</rdfs:label>
    </owl:Class>
    


