        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002306"/>
        <pbpko:IAO_0000115 xml:lang="en">A pathologic distant metastases stage for kidney according to AJCC 7th edition indicating that there is a distant metastases that is histologically confirmed.</pbpko:IAO_0000115>
