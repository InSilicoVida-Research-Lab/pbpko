            </owl:Restriction>
        </rdfs:subClassOf>
        <pbpko:IAO_0000115 xml:lang="en">A planned process with the objective to obtain a material entity for potential use as an input upon which measurements or observations are performed.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>Bjoern Peters</pbpko:IAO_0000117>
        <rdfs:label>specimen collection process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000663 -->

