        </rdfs:subClassOf>
        <pbpko:IAO_0000115 xml:lang="en">Manufacturer role is a role which inheres in a person or organization and which is realized by a manufacturing process.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>GROUP:  Role Branch</pbpko:IAO_0000117>
