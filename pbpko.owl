            </owl:Restriction>
        </rdfs:subClassOf>
        <pbpko:IAO_0000115 xml:lang="en">A regulatory agency is a organization that has responsibility over or for  the legislation (acts and regulations) for a given sector of the government.</pbpko:IAO_0000115>
