    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000713">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000010"/>
        <pbpko:IAO_0000115 xml:lang="en">a software that provides access to more than 100 tools for gene expression analysis, proteomics, SNP analysis and common data processing tasks.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>James Malone</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>Person:Helen Parkinson</pbpko:IAO_0000117>
        <rdfs:label>GenePattern software</rdfs:label>
    </owl:Class>
    


