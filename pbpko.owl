        <pbpko:IAO_0000115 xml:lang="en">A pathologic lymph node stage for lung according to AJCC 7th edition indicating metastasis in contralateral mediastinal, contralateral hilar, ipsilateral or contralateral scalene, or supraclavicular lymph node(s).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>Chris Stoeckert, Helena Ellis</pbpko:IAO_0000117>
        <rdfs:label>pN3 (lung)</rdfs:label>
    </owl:NamedIndividual>
    


