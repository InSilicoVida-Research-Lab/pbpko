        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002298"/>
        <pbpko:IAO_0000115 xml:lang="en">A pathologic distant metastases stage for lung according to AJCC 7th edition indicating that there is a distant metastases that is histologically confirmed and associated with distant lymph nodes or carcinomatosis.</pbpko:IAO_0000115>
