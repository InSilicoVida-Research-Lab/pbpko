        <pbpko:IAO_0000115 xml:lang="en">A pathologic distant metastases stage for lung according to AJCC 7th edition indicating that metastasis is based on clinical assessment and a separate tumor nodule(s) in a contralateral lobe; tumor with pleural nodules OR malignant pleural or pericardial effusion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>Chris Stoeckert, Helena Ellis</pbpko:IAO_0000117>
        <rdfs:label>cM1a (lung)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002302 -->

