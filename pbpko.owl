                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10008"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00103"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10008"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00104"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10008"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00121"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10008"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00521"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10008"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00528"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10009"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00240"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10009"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00243"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/PBPKO_10009"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00244"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <pbpko:IAO_0000115>A physiologically based pharmacokinetic model that treats the entire body as a single, kinetically homogenous unit (central compartment).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>one-compartment pbpk</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00320 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00320">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00446"/>
        <pbpko:IAO_0000115>A compartment in a multi-compartment model representing plasma and highly perfused tissues where distribution is rapid.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>central compartment</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00321 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00321">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00446"/>
        <pbpko:IAO_0000115>A compartment in a multi-compartment model representing tissues where compound distribution is slower compared to the central compartment.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>peripheral compartment</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00322 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00322">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
        <pbpko:IAO_0000115>A biological process involving the irreversible removal of a compound from the body, encompassing metabolism and excretion.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>elimination</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00323 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00323">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00322"/>
        <pbpko:IAO_0000115>An elimination process that follows first-order kinetics (rate proportional to concentration).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>linear elimination</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00324 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00324">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00322"/>
        <pbpko:IAO_0000115>An elimination process that does not follow first-order kinetics (e.g., saturable processes).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>non-linear elimination</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00332 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00332">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00006"/>
        <pbpko:IAO_0000115>A physiological parameter representing distinct phases of an individual&apos;s life (e.g., infant, adult, geriatric).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>lifestage</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/ExO_0000037</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00333 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00333">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing the unborn offspring from the postembryonic stage until birth.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>fetus lifestage</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00334 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00334">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing a very young child, typically under one year of age.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>Inf</oboInOwl:hasSynonymType>
        <rdfs:label>infant lifestage</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00335 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00335">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing a young child, typically between one and three years old.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <oboInOwl:hasSynonymType>Tdl</oboInOwl:hasSynonymType>
        <rdfs:label>toddler lifestage</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00336 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00336">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing individuals typically between 3 and 11 years old.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>child lifestage</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/ExO_0000119</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00337 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00337">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing individuals typically between eleven and fifteen years old.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>teenager lifestage</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00338 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00338">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing the transitional stage between teenager and adulthood (approx. 15-18 years).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>adolescent lifestage</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00339 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00339">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing individuals typically from eighteen to thirty years old.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>adult lifestage</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/UBERON_0007023</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00340 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00340">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing individuals typically from thirty to forty-five years old.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>middle age lifestage</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00341 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00341">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing individuals typically from forty-five to sixty years old (or older, definitions vary).</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>old age lifestage</rdfs:label>
        <skos:closeMatch>http://purl.obolibrary.org/obo/UBERON_0007222</skos:closeMatch>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00342 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00342">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing individuals typically below fifteen years of age.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>pediatric lifestage</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PBPKO_00343 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00343">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00332"/>
        <pbpko:IAO_0000115>A lifestage parameter representing older adults, often considered 60/65 years and older.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117>0000-0001-8345-1349</pbpko:IAO_0000117>
        <pbpko:IAO_0000117>0000-0002-9795-5967</pbpko:IAO_0000117>
        <rdfs:label>geriatric lifestage</rdfs:label>
    </owl:Class>
    


