            </owl:Restriction>
        </rdfs:subClassOf>
        <pbpko:IAO_0000115 xml:lang="en">A plan is a realizable entity that is the inheres in a bearer who is committed to realizing it as a completely executed planned process.</pbpko:IAO_0000115>
        <pbpko:IAO_0000117 xml:lang="en">AR, BP, JM, MC, PRS</pbpko:IAO_0000117>
        <rdfs:label xml:lang="en">plan</rdfs:label>
    </owl:Class>
    


