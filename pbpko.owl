        <pbpko:IAO_0000117>Chris Stoeckert, Helena Ellis</pbpko:IAO_0000117>
        <rdfs:label>cM1 (lung)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002301 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002301">
