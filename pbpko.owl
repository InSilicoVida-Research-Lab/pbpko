    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PBPKO_00521">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PBPKO_00006"/>
        <pbpko:IAO_0000115>A physiological parameter representing the period of lifespan (typically in years) for which the model is simulated.</pbpko:IAO_0000115>
