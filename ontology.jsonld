  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "Blood_flow in pbpk modeling refers to the rate of blood flow to a particular organ or tissue, which is used to calculate the rate of compound delivery to that organ or tissue"
  } ]
}, {
