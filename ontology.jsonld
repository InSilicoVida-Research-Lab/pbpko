    "@id" : "http://purl.obolibrary.org/obo/PBPKO_00265"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "Average time it takes for compound to be absorbed into systemic circulation"
  } ]
