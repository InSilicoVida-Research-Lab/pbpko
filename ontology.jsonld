}, {
  "@id" : "https://github.com/Crispae/pbpko/blob/main/pbpko.owl",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2024-08-11"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "_:genid1"
  }, {
    "@id" : "_:genid2"
  }, {
    "@id" : "_:genid3"
  }, {
    "@id" : "_:genid4"
  }, {
    "@id" : "_:genid5"
  }, {
    "@id" : "_:genid6"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Physiologically Based Pharmacokinetic Models (PBPK) are widely used in both pharmaceutical and environmental domain by experts to assess the kinetics of xenobiotics. Thousands of papers have been published over years but the major drawback being utilization of inconsistent vocabulary which reduce the potential for automation. Machine-readable semantic technology like ontology can be used to improve the reporting of PBPK models. Currently there are multiple ontologies related to life science domain on portals like Bioportal, still there is no dedicated ontology for describing PBPK. The objective of this work is to develop a dedicated ontology for PBPK named PBPKO which can be used in future by wider kinetic community. PBPKO has covered possible mechanisms, existing kinetic terms in multiple databases and commonly utilized terminology by experts. This is freely available ontology with first version (V1.0) being published following FAIR guidelines using ROBOT tool and published at OBO foundry (crispae.github.io/pbpko/ (github.com)). It will be further enriched by including multiple species and much more kinetic terms with the help of experts. PBPKO annotates both physiological and biochemical parameters related to PBPK modeling. This ontology can be further used for text mining of PBPK parameters and model output."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "http://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2025-01-29"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "PBPK ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "PBPK Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://purl.obolibrary.org/obo/bfo/2.0/bfo.owl"
  }, {
    "@id" : "http://purl.obolibrary.org/obo/ro/releases/2024-04-24/ro.owl"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
