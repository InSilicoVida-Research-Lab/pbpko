}, {
  "@id" : "_:genid757",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "https://doi.org/10.3390/nano10071267"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedProperty" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000115"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedSource" : [ {
    "@id" : "http://purl.obolibrary.org/obo/PBPKO_00005"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "Perfusion-limited models are a type of physiologically based pharmacokinetic (pbpk) model that assumes that the concentration of a compound in tissues reaches equilibrium with the compound in the circulation rapidly. in perfusion-limited models, the rate of compound uptake by tissues is limited by blood flow, and the rate of compound elimination is limited by the rate of diffusion from the tissue to the blood"
  } ]
}, {
  "@id" : "_:genid758",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "10.3390/ijerph20043473"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedProperty" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000115"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedSource" : [ {
    "@id" : "http://purl.obolibrary.org/obo/PBPKO_00006"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "Physiological parameters in pbpk modeling provide the structural framework of the model and are used to simulate the absorption, distribution, metabolism, and excretion (adme) of a substance throughout the body. these parameters include body weight, height, organ volume, cardiac output, organ blood flow, and tissue composition."
  } ]
}, {
  "@id" : "_:genid759",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
