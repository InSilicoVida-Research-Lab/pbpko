  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "10.1111/bcp.12685"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedProperty" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000115"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedSource" : [ {
    "@id" : "http://purl.obolibrary.org/obo/PBPKO_00260"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "Aumc is a pharmacokinetic parameter that is calculated by measuring the concentration of a compound in blood plasma as a function of time and then taking the definite integral of the product of time and concentration squared"
  } ]
}, {
  "@id" : "_:genid921",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "Shargel, Leon, et al. Applied Biopharmaceutics & Pharmacokinetics. 7th ed., McGraw-Hill Education, 2015.\nChapter 16, Page Number-471"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedProperty" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000115"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedSource" : [ {
    "@id" : "http://purl.obolibrary.org/obo/PBPKO_00263"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "Bioavailability is defined as the rate and extent to which the active ingredient or active moiety is absorbed from a compound and becomes available at the site of action."
  } ]
}, {
  "@id" : "_:genid922",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "Shargel, Leon, et al. Applied Biopharmaceutics & Pharmacokinetics. 7th ed., McGraw-Hill Education, 2015.\nChapter 16, Page Number-473"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedProperty" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000115"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedSource" : [ {
    "@id" : "http://purl.obolibrary.org/obo/PBPKO_00264"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "Relative bioavailability is a term used to describe the extent and rate at which a compound is absorbed into the systemic circulation after administration compared to a reference compound."
  } ]
}, {
  "@id" : "_:genid923",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "Shargel, Leon, et al. Applied Biopharmaceutics & Pharmacokinetics. 7th ed., McGraw-Hill Education, 2015.Chapter-25,Page number-837"
  } ],
