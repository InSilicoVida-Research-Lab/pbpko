  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "Cardiac output in pbpk modeling refers to the volume of blood pumped by the heart per unit of time, which is used to calculate the rate of blood flow to different organs and tissues in the body"
  } ]
}, {
