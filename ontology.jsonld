    "@id" : "http://purl.obolibrary.org/obo/PBPKO_00007"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "An individual's weight in kilograms divided by the square of the height in meters."
  } ]
}, {
