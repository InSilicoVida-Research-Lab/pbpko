# Class: pbpko:PBPKO_00320 (central compartment)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00320 "A compartment in a multi-compartment model representing plasma and highly perfused tissues where distribution is rapid.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00320 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00320 "0000-0002-9795-5967")
