AnnotationAssertion(pbpko:IAO_0000115 pbpko:CHEBI_24636 "Nuclear particle of charge number +1, spin ½ and rest mass of 1.007276470(12) u.")
AnnotationAssertion(rdfs:label pbpko:CHEBI_24636 "proton")
SubClassOf(pbpko:CHEBI_24636 pbpko:CHEBI_36342)
