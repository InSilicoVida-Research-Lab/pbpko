SubClassOf(pbpko:PBPKO_00320 pbpko:PBPKO_00446)

# Class: pbpko:PBPKO_00321 (peripheral compartment)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00321 "A compartment in a multi-compartment model representing tissues where compound distribution is slower compared to the central compartment.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00321 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00321 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00321 "peripheral compartment")
SubClassOf(pbpko:PBPKO_00321 pbpko:PBPKO_00446)

# Class: pbpko:PBPKO_00322 (elimination)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00322 "A biological process involving the irreversible removal of a compound from the body, encompassing metabolism and excretion.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00322 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00322 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00322 "elimination")
SubClassOf(pbpko:PBPKO_00322 pbpko:GO_0008150)

# Class: pbpko:PBPKO_00323 (linear elimination)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00323 "An elimination process that follows first-order kinetics (rate proportional to concentration).")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00323 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00323 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00323 "linear elimination")
SubClassOf(pbpko:PBPKO_00323 pbpko:PBPKO_00322)

# Class: pbpko:PBPKO_00324 (non-linear elimination)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00324 "An elimination process that does not follow first-order kinetics (e.g., saturable processes).")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00324 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00324 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00324 "non-linear elimination")
SubClassOf(pbpko:PBPKO_00324 pbpko:PBPKO_00322)

