# Class: pbpko:PBPKO_00304 (maximum rate of basolateral transporter in vitro)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00304 "Maximum rate (Vmax) of transport via a basolateral transporter, measured in vitro.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00304 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00304 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00304 "vmax baso in vitro")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00304 "maximum rate of basolateral transporter in vitro")
SubClassOf(pbpko:PBPKO_00304 pbpko:PBPKO_00613)

# Class: pbpko:PBPKO_00305 (Michaelis constant baso)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00305 "Michaelis constant representing the substrate concentration at half-maximal velocity (Km) for a basolateral transporter.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00305 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00305 "0000-0002-9795-5967")
