AnnotationAssertion(rdfs:label pbpko:BFO_0000141 "immaterial entity"@en)
SubClassOf(pbpko:BFO_0000141 pbpko:BFO_0000004)

# Class: pbpko:CHEBI_16670 (peptide)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:CHEBI_16670 "Amide derived from two or more amino carboxylic acid molecules (the same or different) by formation of a covalent bond from the carbonyl carbon of one to the nitrogen atom of another with formal loss of water. The term is usually applied to structures formed from α-amino acids, but it includes those derived from any amino carboxylic acid. X = OH, OR, NH2, NHR, etc.")
AnnotationAssertion(rdfs:label pbpko:CHEBI_16670 "peptide")
SubClassOf(pbpko:CHEBI_16670 pbpko:CHEBI_33839)

# Class: pbpko:CHEBI_24636 (proton)

