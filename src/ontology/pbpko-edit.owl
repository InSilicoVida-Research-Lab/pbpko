# Class: pbpko:OBI_0000017 (regulatory role)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000017 "a role which inheres in material entities and is realized in the processes of making, enforcing or being defined by legislation or orders issued by a governmental body."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000017 "GROUP:  Role branch"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0000017 "regulatory role"@en)
