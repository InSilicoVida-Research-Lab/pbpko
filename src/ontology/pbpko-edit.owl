AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000163 "A dimensionless concentration unit which denotes the mass of a substance in a mixture as a percentage of the mass of the entire mixture.")
AnnotationAssertion(rdfs:label pbpko:UO_0000163 "mass percentage")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000163)

# Individual: pbpko:UO_0000164 (mass volume percentage)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000164 "A dimensionless concentration unit which denotes the mass of the substance in a mixture as a percentage of the volume of the entire mixture.")
AnnotationAssertion(rdfs:label pbpko:UO_0000164 "mass volume percentage")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000164)

# Individual: pbpko:UO_0000165 (volume percentage)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000165 "A dimensionless concentration unit which denotes the volume of the solute in mL per 100 mL of the resulting solution.")
AnnotationAssertion(rdfs:label pbpko:UO_0000165 "volume percentage")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000165)

# Individual: pbpko:UO_0000175 (gram per liter)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000175 "A mass unit density which is equal to mass of an object in grams divided by the volume in liters.")
AnnotationAssertion(rdfs:label pbpko:UO_0000175 "gram per liter")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000175)

# Individual: pbpko:UO_0000176 (milligram per milliliter)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000176 "A mass unit density which is equal to mass of an object in milligrams divided by the volume in milliliters.")
AnnotationAssertion(rdfs:label pbpko:UO_0000176 "milligram per milliliter")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000176)

# Individual: pbpko:UO_0000195 (degree Fahrenheit)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000195 "A temperature unit which is equal to 5/9ths of a kelvin. Negative 40 degrees Fahrenheit is equal to negative 40 degrees Celsius.")
AnnotationAssertion(rdfs:label pbpko:UO_0000195 "degree Fahrenheit")
ClassAssertion(pbpko:UO_0000005 pbpko:UO_0000195)

# Individual: pbpko:UO_0000196 (pH)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000196 "A dimensionless concentration notation which denotes the acidity of a solution in terms of activity of hydrogen ions (H+).")
AnnotationAssertion(rdfs:label pbpko:UO_0000196 "pH")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000196)

# Individual: pbpko:UO_0000207 (milliliter per liter)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000207 "A volume per unit volume unit which is equal to one millionth of a liter of solute in one liter of solution.")
AnnotationAssertion(rdfs:label pbpko:UO_0000207 "milliliter per liter")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000207)

# Individual: pbpko:UO_0000208 (gram per deciliter)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000208 "A mass density unit which is equal to mass of an object in grams divided by the volume in deciliters.")
AnnotationAssertion(rdfs:label pbpko:UO_0000208 "gram per deciliter")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000208)

# Individual: pbpko:UO_0000212 (colony forming unit per volume)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000212 "A concentration unit which a measure of viable bacterial numbers in a given volume.")
AnnotationAssertion(rdfs:label pbpko:UO_0000212 "colony forming unit per volume")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000212)

# Individual: pbpko:UO_0000271 (microliters per minute)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000271 "A volumetric flow rate unit which is equal to one microliter volume through a given surface in one minute.")
AnnotationAssertion(rdfs:label pbpko:UO_0000271 "microliters per minute")
ClassAssertion(pbpko:UO_0000270 pbpko:UO_0000271)

# Individual: pbpko:UO_0000281 (count per nanomolar second)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000281 "A rate unit which is equal to one over one nanomolar second.")
AnnotationAssertion(rdfs:label pbpko:UO_0000281 "count per nanomolar second")
ClassAssertion(pbpko:UO_0000280 pbpko:UO_0000281)

# Individual: pbpko:UO_0000282 (count per molar second)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000282 "A rate unit which is equal to one over one molar second.")
AnnotationAssertion(rdfs:label pbpko:UO_0000282 "count per molar second")
ClassAssertion(pbpko:UO_0000280 pbpko:UO_0000282)

# Individual: pbpko:UO_0000284 (count per nanomolar)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000284 "A rate unit which is equal to one over one nanomolar.")
AnnotationAssertion(rdfs:label pbpko:UO_0000284 "count per nanomolar")
ClassAssertion(pbpko:UO_0000280 pbpko:UO_0000284)

# Individual: pbpko:UO_0000285 (count per molar)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000285 "A rate unit which is equal to one over one molar.")
AnnotationAssertion(rdfs:label pbpko:UO_0000285 "count per molar")
ClassAssertion(pbpko:UO_0000280 pbpko:UO_0000285)

# Individual: pbpko:UO_0000301 (microgram per liter)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:UO_0000301 "A mass unit density which is equal to mass of an object in micrograms divided by the volume in liters.")
AnnotationAssertion(rdfs:label pbpko:UO_0000301 "microgram per liter")
ClassAssertion(pbpko:UO_0000051 pbpko:UO_0000301)


