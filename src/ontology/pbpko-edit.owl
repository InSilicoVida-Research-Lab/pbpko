# Class: pbpko:OBI_0000245 (organization)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000245 "An entity that can bear roles, has members, and has a set of organization rules. Members of organizations are either organizations themselves or individual people. Members can bear specific organization member roles that are determined in the organization rules. The organization rules also determine how decisions are made on behalf of the organization by the organization members."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000245 "PERSON: Alan Ruttenberg")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000245 "PERSON: Bjoern Peters")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000245 "PERSON: Philippe Rocca-Serra")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000245 "PERSON: Susanna Sansone")
AnnotationAssertion(rdfs:label pbpko:OBI_0000245 "organization"@en)
SubClassOf(pbpko:OBI_0000245 pbpko:BFO_0000040)

# Class: pbpko:OBI_0000260 (plan)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000260 "A plan is a realizable entity that is the inheres in a bearer who is committed to realizing it as a completely executed planned process."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000260 "AR, BP, JM, MC, PRS"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0000260 "plan"@en)
SubClassOf(pbpko:OBI_0000260 pbpko:BFO_0000017)
SubClassOf(pbpko:OBI_0000260 ObjectSomeValuesFrom(pbpko:RO_0000059 pbpko:IAO_0000104))

# Class: pbpko:OBI_0000450 (regulatory agency)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000450 "A regulatory agency is a organization that has responsibility over or for  the legislation (acts and regulations) for a given sector of the government."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000450 "GROUP: OBI Biomaterial Branch")
AnnotationAssertion(rdfs:label pbpko:OBI_0000450 "regulatory agency"@en)
