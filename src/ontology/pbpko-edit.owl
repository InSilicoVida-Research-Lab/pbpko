# Class: pbpko:PBPKO_00306 (maximum rate of apical transporter in vitro)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00306 "A maximum rate (Vmax) of an enzyme catalysed reaction for a compound across the apical membrane of an organ, measured in vitro, when the enzyme is saturated with substrate.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00306 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00306 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00306 "vmax apical in vitro")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00306 "maximum rate of apical transporter in vitro")
SubClassOf(pbpko:PBPKO_00306 pbpko:PBPKO_00613)

# Class: pbpko:PBPKO_00307 (Michaelis constant apical)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00307 "Michaelis constant representing the substrate concentration at half-maximal velocity (Km) for an apical transporter.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00307 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00307 "0000-0002-9795-5967")
