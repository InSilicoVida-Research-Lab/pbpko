# Class: pbpko:OBI_0000018 (material supplier role)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000018 "a role realized through the process of supplying materials such as animal subjects, reagents or other materials used in an investigation."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000018 "PERSON:Jennifer Fostel"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0000018 "material supplier role"@en)
