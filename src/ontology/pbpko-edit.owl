AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0002237 "A pathologic primary tumor stage for lung according to AJCC 7th edition indicating that the tumor is more than 2 cm but not more than 3 cm in greatest dimension."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0002237 "Chris Stoeckert, Helena Ellis")
AnnotationAssertion(rdfs:label pbpko:OBI_0002237 "pT1b (lung)")
ClassAssertion(pbpko:OBI_0002232 pbpko:OBI_0002237)

# Individual: pbpko:OBI_0002238 (pT2 (lung))

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0002238 "A pathologic primary tumor stage for lung according to AJCC 7th edition indicating that the tumor is more than 3 cm but not more than 7 cm or the tumor has any of the following features: involves main bronchus, 2 cm or more distal to the carina, invades visceral pleura, associated with atelectasis or obstructive pneumonitis that extends to the hilar region but does not involve the entire lung."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0002238 "Chris Stoeckert, Helena Ellis")
AnnotationAssertion(rdfs:label pbpko:OBI_0002238 "pT2 (lung)")
ClassAssertion(pbpko:OBI_0002232 pbpko:OBI_0002238)

# Individual: pbpko:OBI_0002239 (pT2a (lung))

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0002239 "A pathologic primary tumor stage for lung according to AJCC 7th edition indicating that the tumor is more than 3 cm but not more than 5 cm in greatest dimension."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0002239 "Chris Stoeckert, Helena Ellis")
AnnotationAssertion(rdfs:label pbpko:OBI_0002239 "pT2a (lung)")
ClassAssertion(pbpko:OBI_0002232 pbpko:OBI_0002239)

# Individual: pbpko:OBI_0002240 (pT2b (lung))

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0002240 "A pathologic primary tumor stage for lung according to AJCC 7th edition indicating that the tumor is more than 5 cm but not more than 7 cm in greatest dimension."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0002240 "Chris Stoeckert, Helena Ellis")
AnnotationAssertion(rdfs:label pbpko:OBI_0002240 "pT2b (lung)")
ClassAssertion(pbpko:OBI_0002232 pbpko:OBI_0002240)

# Individual: pbpko:OBI_0002241 (pT3 (lung))

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0002241 "A pathologic primary tumor stage for lung according to AJCC 7th edition indicating that the tumor is more than 7 cm or one that directly invades any of: parietal pleura, chest wall (including superior sulcus tumors), diaphragm, phrenic nerve, mediastinal pleura, parietal pericardiu or the tumor is in the main bronchus less than 2 cm distal to the carina but without  involvement of the carina or there is associated atelectasis or obstructive pneumonitis of the entire lung or there is separate tumor nodule(s) in the same lobe as the primary."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0002241 "Chris Stoeckert, Helena Ellis")
AnnotationAssertion(rdfs:label pbpko:OBI_0002241 "pT3 (lung)")
ClassAssertion(pbpko:OBI_0002232 pbpko:OBI_0002241)

# Individual: pbpko:OBI_0002242 (pT4 (lung))

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0002242 "A pathologic primary tumor stage for lung according to AJCC 7th edition indicating that the tumor of any size that invades any of the following: mediastinum, heart, great vessels, trachea, recurrent laryngeal nerve, esophagus, vertebral body, carina or there is separate tumor nodule(s) in a different ipsilateral lobe to that of the primary."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0002242 "Chris Stoeckert, Helena Ellis")
AnnotationAssertion(rdfs:label pbpko:OBI_0002242 "pT4 (lung)")
ClassAssertion(pbpko:OBI_0002232 pbpko:OBI_0002242)

