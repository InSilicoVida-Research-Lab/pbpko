AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Philippe Rocca-Serra")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Richard Scheuermann"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200000 "Ryan Brinkman"@en)
