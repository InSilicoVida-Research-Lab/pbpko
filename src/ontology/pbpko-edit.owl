# Class: pbpko:OBI_0200166 (data transformation objective)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0200166 "An objective specification to transformation input data into output data"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200166 "James Malone"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0200166 "data transformation objective"@en)
SubClassOf(pbpko:OBI_0200166 pbpko:IAO_0000005)

# Class: pbpko:OBI_0200171 (partitioning data transformation)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0200171 "A partitioning data transformation is a data transformation that has objective partitioning."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200171 "James Malone")
AnnotationAssertion(rdfs:label pbpko:OBI_0200171 "partitioning data transformation"@en)
EquivalentClasses(pbpko:OBI_0200171 ObjectSomeValuesFrom(pbpko:OBI_0000417 pbpko:OBI_0200172))
SubClassOf(pbpko:OBI_0200171 pbpko:OBI_0200000)

# Class: pbpko:OBI_0200172 (partitioning objective)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0200172 "A partitioning objective is a data transformation objective where the aim is to generate a collection of disjoint non-empty subsets whose union equals a non-empty input set."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200172 "Elisabetta Manduchi")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200172 "James Malone"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0200172 "partitioning objective"@en)
SubClassOf(pbpko:OBI_0200172 pbpko:OBI_0200166)

# Class: pbpko:OBI_0200175 (class discovery data transformation)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0200175 "A class discovery data transformation (sometimes called unsupervised classification) is a data transformation that has objective class discovery."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200175 "James Malone")
AnnotationAssertion(rdfs:label pbpko:OBI_0200175 "class discovery data transformation"@en)
EquivalentClasses(pbpko:OBI_0200175 ObjectUnionOf(ObjectSomeValuesFrom(pbpko:OBI_0000299 pbpko:OBI_0000648) ObjectSomeValuesFrom(pbpko:OBI_0000417 pbpko:OBI_0200178)))
SubClassOf(pbpko:OBI_0200175 pbpko:OBI_0200000)

# Class: pbpko:OBI_0200178 (class discovery objective)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0200178 "A class discovery objective (sometimes called unsupervised classification) is a data transformation objective where the aim is to organize input data  (typically vectors of attributes) into classes, where the number of classes and their specifications are not known a priori. Depending on usage, the class assignment can be definite or probabilistic."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200178 "James Malone"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0200178 "class discovery objective"@en)
SubClassOf(pbpko:OBI_0200178 pbpko:OBI_0200166)

# Class: pbpko:OBI_0200179 (class prediction objective)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0200179 "A class prediction objective (sometimes called supervised classification) is a data transformation objective where the aim is to create a predictor from training data through a machine learning technique. The training data consist of pairs of objects (typically vectors of attributes) and
class labels for these objects. The resulting predictor can be used to attach class labels to any valid novel input object. Depending on usage, the prediction can be definite or probabilistic. A classification is learned from the training data and can then be tested on test data."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200179 "James Malone"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0200179 "class prediction objective"@en)
SubClassOf(pbpko:OBI_0200179 pbpko:OBI_0200166)

# Class: pbpko:OBI_0200188 (cross validation objective)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0200188 "A cross validation objective is a data transformation objective in which the aim is to partition a sample of data into subsets such that the analysis is initially performed on a single subset, while the other subset(s) are retained for subsequent use in confirming and validating the initial analysis."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200188 "James Malone"@en)
AnnotationAssertion(rdfs:label pbpko:OBI_0200188 "cross validation objective"@en)
SubClassOf(pbpko:OBI_0200188 pbpko:OBI_0200172)

# Class: pbpko:OBI_0200190 (clustered data visualization)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0200190 "A data visualization which has input of a clustered data set and produces an output of a report graph which is capable of rendering data of this type."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0200190 "James Malone")
AnnotationAssertion(rdfs:label pbpko:OBI_0200190 "clustered data visualization")
SubClassOf(pbpko:OBI_0200190 pbpko:OBI_0200111)
SubClassOf(pbpko:OBI_0200190 ObjectSomeValuesFrom(pbpko:OBI_0000299 ObjectUnionOf(pbpko:IAO_0000037 pbpko:IAO_0000179 pbpko:IAO_0000180 pbpko:IAO_0000183 pbpko:IAO_0000184)))
SubClassOf(pbpko:OBI_0200190 ObjectAllValuesFrom(pbpko:OBI_0000293 pbpko:OBI_0000648))

