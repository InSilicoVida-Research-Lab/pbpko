SubClassOf(pbpko:OBI_0000571 ObjectSomeValuesFrom(pbpko:RO_0000052 ObjectUnionOf(pbpko:NCBITaxon_9606 pbpko:OBI_0000245)))

# Class: pbpko:OBI_0000648 (clustered data set)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000648 "A data set that is produced as the output of a class discovery data transformation and consists of a data set with assigned discovered class labels."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000648 "PERSON: James Malone")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000648 "PERSON: Monnie McGee")
AnnotationAssertion(rdfs:label pbpko:OBI_0000648 "clustered data set"@en)
