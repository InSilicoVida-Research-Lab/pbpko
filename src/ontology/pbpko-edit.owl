AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000658 "An information content entity representing the relationships between data items."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000658 "Melanie Courtot")
AnnotationAssertion(rdfs:label pbpko:OBI_0000658 "data representational model")
SubClassOf(pbpko:OBI_0000658 pbpko:IAO_0000033)

# Class: pbpko:OBI_0000659 (specimen collection process)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000659 "A planned process with the objective to obtain a material entity for potential use as an input upon which measurements or observations are performed."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000659 "Bjoern Peters")
AnnotationAssertion(rdfs:label pbpko:OBI_0000659 "specimen collection process")
