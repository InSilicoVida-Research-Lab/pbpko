# Class: pbpko:PBPKO_00436 (milk plasma ratio)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00436 "A biochemical parameter representing the ratio of compound concentration in milk to plasma.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00436 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00436 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00436 "milk plasma ratio")
SubClassOf(pbpko:PBPKO_00436 pbpko:PBPKO_00139)

# Class: pbpko:PBPKO_00437 (fraction unbound milk)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00437 "An unbound fraction parameter specifically for milk.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00437 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00437 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00437 "fumilk")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00437 "fraction unbound milk")
SubClassOf(pbpko:PBPKO_00437 pbpko:PBPKO_00149)

# Class: pbpko:PBPKO_00438 (concentration in milk)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00438 "The total concentration of compound in the milk compartment.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00438 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00438 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00438 "cmilk")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00438 "concentration in milk")
SubClassOf(pbpko:PBPKO_00438 pbpko:PBPKO_00616)

# Class: pbpko:PBPKO_00439 (daily milk intake)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00439 "A physiological parameter representing the daily volume of milk ingested (e.g., by an infant).")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00439 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00439 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00439 "daily milk intake")
SubClassOf(pbpko:PBPKO_00439 pbpko:PBPKO_00006)

# Class: pbpko:PBPKO_00440 (phmilk)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00440 "A biochemical parameter representing the pH of milk.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00440 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00440 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00440 "phmilk")
SubClassOf(pbpko:PBPKO_00440 pbpko:PBPKO_00139)

# Class: pbpko:PBPKO_00441 (blood milk barrier compartment)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00441 "A barrier compartment representing the physiological barrier separating blood and milk in lactating species.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00441 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00441 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00441 "bmb compartment")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00441 "blood milk barrier compartment")
SubClassOf(pbpko:PBPKO_00441 pbpko:PBPKO_00495)

