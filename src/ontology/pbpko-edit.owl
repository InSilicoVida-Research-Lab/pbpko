# Class: pbpko:OBI_0000112 (specimen role)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OBI_0000112 "A role borne by a material entity that is obtained during a specimen collection process and that can be realized by performing measurements or observations on the specimen."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OBI_0000112 "GROUP:  Role Branch")
AnnotationAssertion(rdfs:label pbpko:OBI_0000112 "specimen role"@en)
