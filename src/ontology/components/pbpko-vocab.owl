############################
#   Classes
############################

# Class: pbpko:PBPKO_00002 (parameter)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00002 "A data item involved in PBPK modelling.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00002 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00002 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00002 "parameter")
SubClassOf(pbpko:PBPKO_00002 pbpko:IAO_0000027)

# Class: pbpko:PBPKO_00003 (physiologically based pharmacokinetic model)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00003 "A data representation model that predicts the absorption, distribution, metabolism, and excretion (ADME) of chemical substances in biological species based on physiological principles using mathematical modelling technique.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00003 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00003 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00003 "PBPK")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00003 "physiologically based pharmacokinetic model")
SubClassOf(pbpko:PBPKO_00003 pbpko:OBI_0000658)

# Class: pbpko:PBPKO_00004 (whole body pbpk)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00004 "A physiologically based pharmacokinetic model that contains an explicit representation of the organs most relevant to the ADME of the compound.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00004 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00004 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00004 "All organs PBPK")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00004 "whole body pbpk")
SubClassOf(pbpko:PBPKO_00004 pbpko:PBPKO_00003)

# Class: pbpko:PBPKO_00005 (perfusion limited model)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00005 "A physiologically based pharmacokinetic model that assumes tissue concentration reaches equilibrium rapidly and uptake/elimination is limited by blood flow rate.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00005 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00005 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00005 "perfusion limited model")
SubClassOf(pbpko:PBPKO_00005 pbpko:PBPKO_00003)

# Class: pbpko:PBPKO_00006 (physiological parameter)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00006 "A parameter that provides the structural framework for a PBPK model and relates to the organism's physiology (e.g., body weight, organ volume, blood flow).")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00006 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00006 "0000-0002-9795-5967")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00006 "physiological parameter")
AnnotationAssertion(skos:closeMatch pbpko:PBPKO_00006 "http://snomed.info/id/398060001")
SubClassOf(pbpko:PBPKO_00006 pbpko:PBPKO_00002)

# Class: pbpko:PBPKO_00007 (body mass index)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00007 "A physiological parameter calculated as an individual's weight (kg) divided by the square of their height (m).")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00007 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00007 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00007 "BMI")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00007 "body mass index")
AnnotationAssertion(skos:closeMatch pbpko:PBPKO_00007 "http://www.ebi.ac.uk/efo/EFO_0004340")
SubClassOf(pbpko:PBPKO_00007 pbpko:PBPKO_00006)

# Class: pbpko:PBPKO_00008 (bodyweight)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:PBPKO_00008 "A physiological parameter representing the mass or quantity of heaviness of an individual.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00008 "0000-0001-8345-1349")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:PBPKO_00008 "0000-0002-9795-5967")
AnnotationAssertion(oboInOwl:hasSynonymType pbpko:PBPKO_00008 "bw")
AnnotationAssertion(rdfs:label pbpko:PBPKO_00008 "bodyweight")
AnnotationAssertion(skos:closeMatch pbpko:PBPKO_00008 "http://purl.obolibrary.org/obo/CMO_0000012")
