############################
#   Annotation Properties
############################

# Annotation Property: pbpko:IAO_0000115 (definition)

AnnotationAssertion(rdfs:label pbpko:IAO_0000115 "definition"@en)

# Annotation Property: pbpko:IAO_0000117 (term editor)

AnnotationAssertion(rdfs:label pbpko:IAO_0000117 "term editor"@en)



############################
#   Classes
############################

# Class: pbpko:BFO_0000001 (entity)

AnnotationAssertion(rdfs:label pbpko:BFO_0000001 "entity"@en)

# Class: pbpko:BFO_0000002 (continuant)

AnnotationAssertion(rdfs:label pbpko:BFO_0000002 "continuant"@en)
SubClassOf(pbpko:BFO_0000002 pbpko:BFO_0000001)

# Class: pbpko:BFO_0000004 (independent continuant)

AnnotationAssertion(rdfs:label pbpko:BFO_0000004 "independent continuant"@en)
SubClassOf(pbpko:BFO_0000004 pbpko:BFO_0000002)

# Class: pbpko:BFO_0000029 (site)

AnnotationAssertion(rdfs:label pbpko:BFO_0000029 "site"@en)
SubClassOf(pbpko:BFO_0000029 pbpko:BFO_0000141)

# Class: pbpko:BFO_0000040 (material entity)

AnnotationAssertion(rdfs:label pbpko:BFO_0000040 "material entity"@en)
SubClassOf(pbpko:BFO_0000040 pbpko:BFO_0000004)
DisjointClasses(pbpko:BFO_0000040 pbpko:BFO_0000141)

# Class: pbpko:BFO_0000141 (immaterial entity)

AnnotationAssertion(rdfs:label pbpko:BFO_0000141 "immaterial entity"@en)
SubClassOf(pbpko:BFO_0000141 pbpko:BFO_0000004)


