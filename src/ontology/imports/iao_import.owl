############################
#   Classes
############################

# Class: pbpko:BFO_0000001 (entity)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000001 "Julius Caesar"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000001 "Verdi’s Requiem"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000001 "the Second World War"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000001 "your body mass index"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:BFO_0000001 "BFO 2 Reference: In all areas of empirical inquiry we encounter general terms of two sorts. First are general terms which refer to universals or types:animaltuberculosissurgical procedurediseaseSecond, are general terms used to refer to groups of entities which instantiate a given universal but do not correspond to the extension of any subuniversal of that universal because there is nothing intrinsic to the entities in question by virtue of which they – and only they – are counted as belonging to the given group. Examples are: animal purchased by the Emperortuberculosis diagnosed on a Wednesdaysurgical procedure performed on a patient from Stockholmperson identified as candidate for clinical trial #2056-555person who is signatory of Form 656-PPVpainting by Leonardo da VinciSuch terms, which represent what are called ‘specializations’ in [81"@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000001 "entity"@en)

# Class: pbpko:BFO_0000002 (continuant)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:BFO_0000002 "An entity that exists in full at any time in which it exists at all, persists through time while maintaining its identity and has no temporal parts."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:BFO_0000002 "BFO 2 Reference: Continuant entities are entities which can be sliced to yield parts only along the spatial dimension, yielding for example the parts of your table which we call its legs, its top, its nails. ‘My desk stretches from the window to the door. It has spatial parts, and can be sliced (in space) in two. With respect to time, however, a thing is a continuant.’ [60, p. 240"@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000002 "continuant"@en)
SubClassOf(pbpko:BFO_0000002 pbpko:BFO_0000001)

# Class: pbpko:BFO_0000004 (independent continuant)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "a chair"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "a heart"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "a leg"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "a molecule"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "a spatial region"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "an atom"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "an orchestra."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "an organism"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "the bottom right portion of a human torso"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000004 "the interior of your mouth"@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000004 "independent continuant"@en)
SubClassOf(pbpko:BFO_0000004 pbpko:BFO_0000002)
DisjointClasses(pbpko:BFO_0000004 pbpko:BFO_0000020)
DisjointClasses(pbpko:BFO_0000004 pbpko:BFO_0000031)

# Class: pbpko:BFO_0000016 (disposition)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000016 "an atom of element X has the disposition to decay to an atom of element Y"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000016 "certain people have a predisposition to colon cancer"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000016 "children are innately disposed to categorize objects in certain ways."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000016 "the cell wall is disposed to filter chemicals in endocytosis and exocytosis"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:BFO_0000016 "BFO 2 Reference: Dispositions exist along a strength continuum. Weaker forms of disposition are realized in only a fraction of triggering cases. These forms occur in a significant number of cases of a similar type."@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000016 "disposition"@en)
SubClassOf(pbpko:BFO_0000016 pbpko:BFO_0000017)
DisjointClasses(pbpko:BFO_0000016 pbpko:BFO_0000023)

# Class: pbpko:BFO_0000017 (realizable entity)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000017 "the disposition of this piece of metal to conduct electricity."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000017 "the disposition of your blood to coagulate"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000017 "the function of your reproductive organs"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000017 "the role of being a doctor"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000017 "the role of this boundary to delineate where Utah and Colorado meet"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:BFO_0000017 "A specifically dependent continuant  that inheres in continuant  entities and are not exhibited in full at every time in which it inheres in an entity or group of entities. The exhibition or actualization of a realizable entity is a particular manifestation, functioning or process that occurs under certain circumstances."@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000017 "realizable entity"@en)
SubClassOf(pbpko:BFO_0000017 pbpko:BFO_0000020)
DisjointClasses(pbpko:BFO_0000017 pbpko:BFO_0000019)

# Class: pbpko:BFO_0000019 (quality)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000019 "the ambient temperature of this portion of air"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000019 "the color of a tomato"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000019 "the length of the circumference of your waist"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000019 "the mass of this piece of gold."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000019 "the shape of your nose"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000019 "the shape of your nostril"@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000019 "quality"@en)
SubClassOf(pbpko:BFO_0000019 pbpko:BFO_0000020)

# Class: pbpko:BFO_0000020 (specifically dependent continuant)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "Reciprocal specifically dependent continuants: the function of this key to open this lock and the mutually dependent disposition of this lock: to be opened by this key"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "of one-sided specifically dependent continuants: the mass of this tomato"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "of relational dependent continuants (multiple bearers): John’s love for Mary, the ownership relation between John and this statue, the relation of authority between John and his subordinates."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "the disposition of this fish to decay"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "the function of this heart: to pump blood"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "the mutual dependence of proton donors and acceptors in chemical reactions [79"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "the mutual dependence of the role predator and the role prey as played by two organisms in a given interaction"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "the pink color of a medium rare piece of grilled filet mignon at its center"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "the role of being a doctor"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "the shape of this hole."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000020 "the smell of this portion of mozzarella"@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000020 "specifically dependent continuant"@en)
SubClassOf(pbpko:BFO_0000020 pbpko:BFO_0000002)
DisjointClasses(pbpko:BFO_0000020 pbpko:BFO_0000031)

# Class: pbpko:BFO_0000023 (role)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000023 "John’s role of husband to Mary is dependent on Mary’s role of wife to John, and both are dependent on the object aggregate comprising John and Mary as member parts joined together through the relational quality of being married."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000023 "the priest role"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000023 "the role of a boundary to demarcate two neighboring administrative territories"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000023 "the role of a building in serving as a military target"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000023 "the role of a stone in marking a property boundary"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000023 "the role of subject in a clinical trial"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000023 "the student role"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:BFO_0000023 "A realizable entity  the manifestation of which brings about some result or end that is not essential to a continuant  in virtue of the kind of thing that it is but that can be served or participated in by that kind of continuant  in some kinds of natural, social or institutional contexts."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:BFO_0000023 "BFO 2 Reference: One major family of examples of non-rigid universals involves roles, and ontologies developed for corresponding administrative purposes may consist entirely of representatives of entities of this sort. Thus ‘professor’, defined as follows,b instance_of professor at t =Def. there is some c, c instance_of professor role & c inheres_in b at t.denotes a non-rigid universal and so also do ‘nurse’, ‘student’, ‘colonel’, ‘taxpayer’, and so forth. (These terms are all, in the jargon of philosophy, phase sortals.) By using role terms in definitions, we can create a BFO conformant treatment of such entities drawing on the fact that, while an instance of professor may be simultaneously an instance of trade union member, no instance of the type professor role is also (at any time) an instance of the type trade union member role (any more than any instance of the type color is at any time an instance of the type length).If an ontology of employment positions should be defined in terms of roles following the above pattern, this enables the ontology to do justice to the fact that individuals instantiate the corresponding universals –  professor, sergeant, nurse – only during certain phases in their lives."@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000023 "role"@en)
SubClassOf(pbpko:BFO_0000023 pbpko:BFO_0000017)

# Class: pbpko:BFO_0000031 (generically dependent continuant)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000031 "The entries in your database are patterns instantiated as quality instances in your hard drive. The database itself is an aggregate of such patterns. When you create the database you create a particular instance of the generically dependent continuant type database. Each entry in the database is an instance of the generically dependent continuant type IAO: information content entity."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000031 "the pdf file on your laptop, the pdf file that is a copy thereof on my laptop"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000031 "the sequence of this protein molecule; the sequence that is a copy thereof in that protein molecule."@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000031 "generically dependent continuant"@en)
SubClassOf(pbpko:BFO_0000031 pbpko:BFO_0000002)

# Class: pbpko:BFO_0000034 (function)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000034 "the function of a hammer to drive in nails"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000034 "the function of a heart pacemaker to regulate the beating of a heart through electricity"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000034 "the function of amylase in saliva to break down starch into sugar"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:BFO_0000034 "BFO 2 Reference: In the past, we have distinguished two varieties of function, artifactual function and biological function. These are not asserted subtypes of BFO:function however, since the same function – for example: to pump, to transport – can exist both in artifacts and in biological entities. The asserted subtypes of function that would be needed in order to yield a separate monoheirarchy are not artifactual function, biological function, etc., but rather transporting function, pumping function, etc."@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000034 "function"@en)
SubClassOf(pbpko:BFO_0000034 pbpko:BFO_0000016)

# Class: pbpko:BFO_0000040 (material entity)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "a flame"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "a forest fire"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "a human being"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "a hurricane"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "a photon"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "a puff of smoke"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "a sea wave"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "a tornado"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "an aggregate of human beings."@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "an energy wave"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "an epidemic"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:BFO_0000040 "the undetached arm of a human being"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:BFO_0000040 "An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:BFO_0000040 "BFO 2 Reference: Material entities (continuants) can preserve their identity even while gaining and losing material parts. Continuants are contrasted with occurrents, which unfold themselves in successive temporal parts or phases [60"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:BFO_0000040 "BFO 2 Reference: Object, Fiat Object Part and Object Aggregate are not intended to be exhaustive of Material Entity. Users are invited to propose new subcategories of Material Entity."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:BFO_0000040 "BFO 2 Reference: ‘Matter’ is intended to encompass both mass and energy (we will address the ontological treatment of portions of energy in a later version of BFO). A portion of matter is anything that includes elementary particles among its proper or improper parts: quarks and leptons, including electrons, as the smallest particles thus far discovered; baryons (including protons and neutrons) at a higher level of granularity; atoms and molecules at still higher levels, forming the cells, organs, organisms and other material entities studied by biologists, the portions of rock studied by geologists, the fossils studied by paleontologists, and so on.Material entities are three-dimensional entities (entities extended in three spatial dimensions), as contrasted with the processes in which they participate, which are four-dimensional entities (entities extended also along the dimension of time).According to the FMA, material entities may have immaterial entities as parts – including the entities identified below as sites; for example the interior (or ‘lumen’) of your small intestine is a part of your body. BFO 2.0 embodies a decision to follow the FMA here."@en)
AnnotationAssertion(rdfs:label pbpko:BFO_0000040 "material entity"@en)
SubClassOf(pbpko:BFO_0000040 pbpko:BFO_0000004)

# Class: pbpko:IAO_0000027 (data entity)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000027 "data entity"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:IAO_0000027 "Data items include counts of things, analyte concentrations, and statistical summaries."@en)
AnnotationAssertion(pbpko:IAO_0000114 pbpko:IAO_0000027 pbpko:IAO_0000125)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000027 "An information content entity that is intended to be one or more truthful statement(s) about something (modulo, e.g., measurement precision or other systematic errors) and is constructed/acquired by a method which reliably tends to produce (approximately) truthful statements."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000027 "2/2/2009 Alan and Bjoern discussing FACS run output data. This is a data item because it is about the cell population. Each element records an event and is typically further composed a set of measurment data items that record the fluorescent intensity stimulated by one of the lasers."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000027 "2009-03-16: data item deliberatly ambiguous: we merged data set and datum to be one entity, not knowing how to define singular versus plural. So data item is more general than datum."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000027 "2009-03-16: removed datum as alternative term as datum specifically refers to singular form, and is thus not an exact synonym."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000027 "2014-03-31: See discussion at http://odontomachus.wordpress.com/2014/03/30/aboutness-objects-propositions/")
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000027 "JAR: datum     -- well, this will be very tricky to define, but maybe some 
information-like stuff that might be put into a computer and that is 
meant, by someone, to denote and/or to be interpreted by some 
process... I would include lists, tables, sentences... I think I might 
defer to Barry, or to Brian Cantwell Smith

JAR: A data item is an approximately justified approximately true approximate belief"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000027 "PERSON: Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000027 "PERSON: Chris Stoeckert"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000027 "PERSON: Jonathan Rees"@en)
AnnotationAssertion(pbpko:IAO_0000118 pbpko:IAO_0000027 "data"@en)
AnnotationAssertion(pbpko:IAO_0000118 pbpko:IAO_0000027 "data item"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000027 "data entity"@en)
SubClassOf(pbpko:IAO_0000027 pbpko:IAO_0000030)

# Class: pbpko:IAO_0000030 (information content entity)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000030 "information content entity"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:IAO_0000030 "Examples of information content entites include journal articles, data, graphical layouts, and graphs."@en)
AnnotationAssertion(pbpko:IAO_0000114 pbpko:IAO_0000030 pbpko:IAO_0000122)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000030 "A generically dependent continuant that is about some thing."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000030 "2014-03-10: The use of \"thing\" is intended to be general enough to include universals and configurations (see https://groups.google.com/d/msg/information-ontology/GBxvYZCk1oc/-L6B5fSBBTQJ)."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000030 "information_content_entity 'is_encoded_in' some digital_entity in obi before split (040907). information_content_entity 'is_encoded_in' some physical_document in obi before split (040907).

Previous. An information content entity is a non-realizable information entity that 'is encoded in' some digital or physical entity."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000030 "PERSON: Chris Stoeckert"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000030 "OBI_0000142"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000030 "information content entity"@en)
SubClassOf(pbpko:IAO_0000030 pbpko:BFO_0000031)
SubClassOf(pbpko:IAO_0000030 ObjectSomeValuesFrom(pbpko:IAO_0000136 pbpko:BFO_0000001))

# Class: pbpko:IAO_0000078 (curation status specification)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000078 "curation status specification"@en)
AnnotationAssertion(pbpko:IAO_0000114 pbpko:IAO_0000078 pbpko:IAO_0000125)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000078 "The curation status of the term. The allowed values come from an enumerated list of predefined terms. See the specification of these instances for more detailed definitions of each enumerated value."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000078 "Better to represent curation as a process with parts and then relate labels to that process (in IAO meeting)"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000078 "PERSON:Bill Bug"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000078 "GROUP:OBI:<http://purl.obolibrary.org/obo/obi>"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000078 "OBI_0000266"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000078 "curation status specification"@en)
EquivalentClasses(pbpko:IAO_0000078 ObjectOneOf(pbpko:IAO_0000002 pbpko:IAO_0000120 pbpko:IAO_0000121 pbpko:IAO_0000122 pbpko:IAO_0000123 pbpko:IAO_0000124 pbpko:IAO_0000125 pbpko:IAO_0000423 pbpko:IAO_0000428))
SubClassOf(pbpko:IAO_0000078 pbpko:IAO_0000102)

# Class: pbpko:IAO_0000100 (homogenous data collection)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000100 "homogenous data collection"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:IAO_0000100 "Intensity values in a CEL file or from multiple CEL files comprise a data set (as opposed to the CEL files themselves)."@en)
AnnotationAssertion(pbpko:IAO_0000114 pbpko:IAO_0000100 pbpko:IAO_0000125)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000100 "A data item that is an aggregate of other data items of the same type that have something in common. Averages and distributions can be determined for data sets."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000100 "2009/10/23 Alan Ruttenberg. The intention is that this term represent collections of like data. So this isn't for, e.g. the whole contents of a cel file, which includes parameters, metadata etc. This is more like java arrays of a certain rather specific type"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000100 "2014-05-05: Data sets are aggregates and thus must include two or more data items. We have chosen not to add logical axioms to make this restriction.")
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000100 "person:Allyson Lister"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000100 "person:Chris Stoeckert"@en)
AnnotationAssertion(pbpko:IAO_0000118 pbpko:IAO_0000100 "data set"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000100 "group:OBI"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000100 "homogenous data collection"@en)
SubClassOf(pbpko:IAO_0000100 pbpko:IAO_0001000)

# Class: pbpko:IAO_0000102 (data about an ontology part)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000102 "data about an ontology part"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000102 "Data about an ontology part is a data item about a part of an ontology, for example a term"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000102 "Person:Alan Ruttenberg"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000102 "data about an ontology part"@en)
SubClassOf(pbpko:IAO_0000102 pbpko:IAO_0000027)

# Class: pbpko:IAO_0000225 (obsolescence reason specification)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000225 "obsolescence reason specification"@en)
AnnotationAssertion(pbpko:IAO_0000114 pbpko:IAO_0000225 pbpko:IAO_0000125)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000225 "The reason for which a term has been deprecated. The allowed values come from an enumerated list of predefined terms. See the specification of these instances for more detailed definitions of each enumerated value."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000225 "The creation of this class has been inspired in part by Werner Ceusters' paper, Applying evolutionary terminology auditing to the Gene Ontology."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000225 "PERSON: Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000225 "PERSON: Melanie Courtot"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000225 "obsolescence reason specification"@en)
EquivalentClasses(pbpko:IAO_0000225 ObjectOneOf(pbpko:IAO_0000103 pbpko:IAO_0000226 pbpko:IAO_0000227 pbpko:IAO_0000228 pbpko:IAO_0000229 pbpko:OMO_0001000))
SubClassOf(pbpko:IAO_0000225 pbpko:IAO_0000102)

# Class: pbpko:IAO_0000409 (denotator type)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000409 "denotator type"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:IAO_0000409 "The Basic Formal Ontology ontology makes a distinction between Universals and defined classes, where the formal are \"natural kinds\" and the latter arbitrary collections of entities."@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000409 "A denotator type indicates how a term should be interpreted from an ontological perspective."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000409 "Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000409 "Barry Smith, Werner Ceusters"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000409 "denotator type"@en)
EquivalentClasses(pbpko:IAO_0000409 ObjectOneOf(pbpko:IAO_0000410 pbpko:IAO_0000420 pbpko:IAO_0000421))
SubClassOf(pbpko:IAO_0000409 pbpko:IAO_0000102)

# Class: pbpko:IAO_0001000 (data collection)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0001000 "data collection"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0001000 "A data entity that consists of multiple data entities."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0001000 "Sebastian Duesing")
AnnotationAssertion(pbpko:IAO_0000118 pbpko:IAO_0001000 "data set"@en)
AnnotationAssertion(pbpko:IAO_0000233 pbpko:IAO_0001000 "https://github.com/information-artifact-ontology/IAO/issues/283")
AnnotationAssertion(pbpko:IAO_0000233 pbpko:IAO_0001000 "https://github.com/obi-ontology/obi/issues/1877")
AnnotationAssertion(rdfs:label pbpko:IAO_0001000 "data collection"@en)
SubClassOf(pbpko:IAO_0001000 pbpko:IAO_0000027)


############################
#   Named Individuals
############################

# Individual: pbpko:IAO_0000002 (example to be eventually removed)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000002 "example to be eventually removed"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000002 "example to be eventually removed"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000002)

# Individual: pbpko:IAO_0000103 (failed exploratory term)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000103 "failed exploratory term"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000103 "The term was initially used in an attempt to structure part of the ontology, but in retrospect failed to do a good job."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000103 "Terms created as placeholders with the expectation of being permanent should instead be deprecated using the \"placeholder removed\" (obo:IAO_0000226) justification."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000103 "Person:Alan Ruttenberg"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000103 "failed exploratory term"@en)
ClassAssertion(pbpko:IAO_0000225 pbpko:IAO_0000103)

# Individual: pbpko:IAO_0000120 (metadata complete)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000120 "metadata complete"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000120 "Class has all its metadata, but is either not guaranteed to be in its final location in the asserted IS_A hierarchy or refers to another class that is not complete."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000120 "metadata complete"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000120)

# Individual: pbpko:IAO_0000121 (organizational term)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000121 "organizational term"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000121 "The term was created to ease viewing/sorting terms for development purposes, but will not be included in a release."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000121 "organizational term"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000121)

# Individual: pbpko:IAO_0000122 (ready for release)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000122 "ready for release"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000122 "Class has undergone final review, is ready for use, and will be included in the next release. Any class lacking \"ready_for_release\" should be considered likely to change place in hierarchy, have its definition refined, or be obsoleted in the next release.  Those classes deemed \"ready_for_release\" will also derived from a chain of ancestor classes that are also \"ready_for_release.\""@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000122 "ready for release"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000122)

# Individual: pbpko:IAO_0000123 (metadata incomplete)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000123 "metadata incomplete"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000123 "Class is being worked on; however, the metadata (including definition) are not complete or sufficiently clear to the branch editors."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000123 "metadata incomplete"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000123)

# Individual: pbpko:IAO_0000124 (uncurated)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000124 "uncurated"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000124 "Nothing done yet beyond assigning a unique class ID and proposing a preferred term."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000124 "uncurated"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000124)

# Individual: pbpko:IAO_0000125 (pending final vetting)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000125 "pending final vetting"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000125 "All definitions, placement in the asserted IS_A hierarchy and required minimal metadata are complete. The class is awaiting a final review by someone other than the term editor."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000125 "pending final vetting"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000125)

# Individual: pbpko:IAO_0000226 (placeholder removed)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000226 "placeholder removed"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000226 "The term was created to temporarily stand in for a semantic purpose, but is no longer needed, typically due to another permanent term being defined."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000226 "This reason is appropriate for a temporary term even if no permanent term is defined; for example if the need for the term no longer exists. If a permanent (replacement) term is defined, the deprecated term should reference the replacement with IAO:0100001. If no replacement is defined, it may be appropriate to reference alternative terms with oboInOwl:consider."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000226 "placeholder removed"@en)
ClassAssertion(pbpko:IAO_0000225 pbpko:IAO_0000226)

# Individual: pbpko:IAO_0000227 (terms merged)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000227 "terms merged"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000227 "The term has been combined with one or more other terms to create a more encompassing (merged) term."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000227 "The deprecated term should reference the merged term with obo:IAO_0100001. The replacement term should reference the original terms as sources using obo:RO_0001000 (derives_from). An editor note should explain what were the merged terms and the reason for the merge."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000227 "terms merged"@en)
ClassAssertion(pbpko:IAO_0000225 pbpko:IAO_0000227)

# Individual: pbpko:IAO_0000228 (term imported)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000228 "term imported"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000228 "The term has been replaced by a term imported from another ontology."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000228 "This is to be used when the original term has been replaced by a term imported from an other ontology. The deprecated term should reference the imported term with obo:IAO_0100001."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000228 "term imported"@en)
ClassAssertion(pbpko:IAO_0000225 pbpko:IAO_0000228)

# Individual: pbpko:IAO_0000229 (term split)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000229 "term split"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000229 "The term has been split into two or more new terms."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000229 "This is to be used when a term has been split in two or more new terms. An editor note should indicate the reason for the split. The deprecated term should reference the replacement terms with obo:IAO_0100001."@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000229 "term split"@en)
ClassAssertion(pbpko:IAO_0000225 pbpko:IAO_0000229)

# Individual: pbpko:IAO_0000410 (universal)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000410 "universal"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000410 "Hard to give a definition for. Intuitively a \"natural kind\" rather than a collection of any old things, which a class is able to be, formally. At the meta level, universals are defined as positives, are disjoint with their siblings, have single asserted parents."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000410 "Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000410 "A Formal Theory of Substances, Qualities, and Universals, http://ontology.buffalo.edu/bfo/SQU.pdf"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000410 "universal"@en)
ClassAssertion(pbpko:IAO_0000409 pbpko:IAO_0000410)

# Individual: pbpko:IAO_0000420 (defined class)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000420 "defined class"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000420 "A defined class is a class that is defined by a set of logically necessary and sufficient conditions but is not a universal"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000420 "\"definitions\", in some readings, always are given by necessary and sufficient conditions. So one must be careful (and this is difficult sometimes) to distinguish between defined classes and universal."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000420 "Alan Ruttenberg"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000420 "defined class"@en)
ClassAssertion(pbpko:IAO_0000409 pbpko:IAO_0000420)

# Individual: pbpko:IAO_0000421 (named class expression)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000421 "named class expression"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000421 "A named class expression is a logical expression that is given a name. The name can be used in place of the expression."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000421 "named class expressions are used in order to have more concise logical definition but their extensions may not be interesting classes on their own. In languages such as OWL, with no provisions for macros, these show up as actuall classes. Tools may with to not show them as such, and to replace uses of the macros with their expansions"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000421 "Alan Ruttenberg"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000421 "named class expression"@en)
ClassAssertion(pbpko:IAO_0000409 pbpko:IAO_0000421)

# Individual: pbpko:IAO_0000423 (to be replaced with external ontology term)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000423 "to be replaced with external ontology term"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000423 "Terms with this status should eventually replaced with a term from another ontology."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000423 "Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000423 "group:OBI"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000423 "to be replaced with external ontology term"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000423)

# Individual: pbpko:IAO_0000428 (requires discussion)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:IAO_0000428 "requires discussion"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000428 "A term that is metadata complete, has been reviewed, and problems have been identified that require discussion before release. Such a term requires editor note(s) to identify the outstanding issues."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000428 "Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000428 "group:OBI"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000428 "requires discussion"@en)
ClassAssertion(pbpko:IAO_0000078 pbpko:IAO_0000428)

# Individual: pbpko:OMO_0001000 (out of scope)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OMO_0001000 "The term was added to the ontology on the assumption it was in scope, but it turned out later that it was not."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:OMO_0001000 "This obsolesence reason should be used conservatively. Typical valid examples in disease ontologies are: unnecessary class grouping; mistaked creation of a disease associated to a phenotype."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OMO_0001000 <http://orcid.org/0000-0001-5208-3432>)
AnnotationAssertion(pbpko:IAO_0000233 pbpko:OMO_0001000 "https://github.com/information-artifact-ontology/ontology-metadata/issues/77")
AnnotationAssertion(rdfs:label pbpko:OMO_0001000 "out of scope")
ClassAssertion(pbpko:IAO_0000225 pbpko:OMO_0001000)

# Individual: pbpko:OMO_0001002 (domain entity does not exist)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:OMO_0001002 "The term was added to the ontology on the assumption it was a valid domain entity, but it turns out the entity does not exist in reality."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:OMO_0001002 "This obsolesence reason should be used conservatively. For example: Obsoleting class that describes a breed of cow based on a record in an existing database, that was later retracted as faulty (breed does not exist). Do not use this term to obsolete a historic concept (that was once valid, but not anymore). "@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:OMO_0001002 <http://orcid.org/0000-0002-4142-7153>)
AnnotationAssertion(pbpko:IAO_0000233 pbpko:OMO_0001002 "https://github.com/information-artifact-ontology/ontology-metadata/issues/136")
AnnotationAssertion(rdfs:label pbpko:OMO_0001002 "domain entity does not exist")
ClassAssertion(pbpko:IAO_0000225 pbpko:OMO_0001002)


