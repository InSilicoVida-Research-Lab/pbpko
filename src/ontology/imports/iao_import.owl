ObjectPropertyRange(pbpko:RO_0000087 pbpko:BFO_0000023)

# Object Property: pbpko:RO_0000091 (has disposition)

AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000091 "a relation between an independent continuant (the bearer) and a disposition, in which the disposition specifically depends on the bearer for its existence"@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000091 "has disposition"@en)
SubObjectPropertyOf(pbpko:RO_0000091 pbpko:RO_0000053)
InverseObjectProperties(pbpko:RO_0000091 pbpko:RO_0000092)
