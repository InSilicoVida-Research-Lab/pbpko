AnnotationAssertion(pbpko:IAO_0000114 pbpko:IAO_0000119 pbpko:IAO_0000122)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000119 "Formal citation, e.g. identifier in external database to indicate / attribute source(s) for the definition. Free text indicate / attribute source(s) for the definition. EXAMPLE: Author Name, URI, MeSH Term C04, PUBMED ID, Wiki uri on 31.01.2007"@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000119 "PERSON:Daniel Schober"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000119 "Discussion on obo-discuss mailing-list, see http://bit.ly/hgm99w"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000119 "GROUP:OBI:<http://purl.obolibrary.org/obo/obi>"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000119 "definition source"@en)

