ObjectPropertyRange(pbpko:RO_0000091 pbpko:BFO_0000016)

# Object Property: pbpko:RO_0000092 (disposition of)

AnnotationAssertion(rdfs:label pbpko:RO_0000092 "disposition of"@en)
