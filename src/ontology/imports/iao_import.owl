# Object Property: pbpko:IAO_0000136 (is about)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:IAO_0000136 "This document is about information artifacts and their representations"@en)
AnnotationAssertion(pbpko:IAO_0000114 pbpko:IAO_0000136 pbpko:IAO_0000125)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:IAO_0000136 "A (currently) primitive relation that relates an information artifact to an entity."@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:IAO_0000136 "7/6/2009 Alan Ruttenberg. Following discussion with Jonathan Rees, and introduction of \"mentions\" relation. Weaken the is_about relationship to be primitive. 

We will try to build it back up by elaborating the various subproperties that are more precisely defined.

Some currently missing phenomena that should be considered \"about\" are predications - \"The only person who knows the answer is sitting beside me\" , Allegory, Satire, and other literary forms that can be topical without explicitly mentioning the topic."@en)
AnnotationAssertion(pbpko:IAO_0000117 pbpko:IAO_0000136 "person:Alan Ruttenberg"@en)
AnnotationAssertion(pbpko:IAO_0000119 pbpko:IAO_0000136 "Smith, Ceusters, Ruttenberg, 2000 years of philosophy"@en)
AnnotationAssertion(rdfs:label pbpko:IAO_0000136 "is about"@en)
ObjectPropertyDomain(pbpko:IAO_0000136 pbpko:IAO_0000030)

# Object Property: pbpko:RO_0000052 (characteristic of)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:RO_0000052 "inheres in"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:RO_0000052 "this fragility is a characteristic of this vase"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:RO_0000052 "this red color is a characteristic of this apple"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000052 "a relation between a specifically dependent continuant (the characteristic) and any other entity (the bearer), in which the characteristic depends on the bearer for its existence."@en)
AnnotationAssertion(pbpko:IAO_0000118 pbpko:RO_0000052 "inheres_in"@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000052 "characteristic of"@en)
InverseObjectProperties(pbpko:RO_0000052 pbpko:RO_0000053)
FunctionalObjectProperty(pbpko:RO_0000052)

# Object Property: pbpko:RO_0000053 (has characteristic)

AnnotationAssertion(pbpko:IAO_0000111 pbpko:RO_0000053 "bearer of"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:RO_0000053 "this apple is bearer of this red color"@en)
AnnotationAssertion(pbpko:IAO_0000112 pbpko:RO_0000053 "this vase is bearer of this fragility"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000053 "Inverse of characteristic_of"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:RO_0000053 "A bearer can have many dependents, and its dependents can exist for different periods of time, but none of its dependents can exist when the bearer does not exist."@en)
AnnotationAssertion(pbpko:IAO_0000118 pbpko:RO_0000053 "bearer_of"@en)
AnnotationAssertion(pbpko:IAO_0000118 pbpko:RO_0000053 "is bearer of"@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000053 "has characteristic"@en)
InverseFunctionalObjectProperty(pbpko:RO_0000053)
ObjectPropertyRange(pbpko:RO_0000053 pbpko:BFO_0000020)

# Object Property: pbpko:RO_0000079 (function of)

AnnotationAssertion(pbpko:IAO_0000112 pbpko:RO_0000079 "this catalysis function is a function of this enzyme"@en)
AnnotationAssertion(pbpko:IAO_0000115 pbpko:RO_0000079 "a relation between a function and an independent continuant (the bearer), in which the function specifically depends on the bearer for its existence"@en)
AnnotationAssertion(pbpko:IAO_0000116 pbpko:RO_0000079 "A function inheres in its bearer at all times for which the function exists, however the function need not be realized at all the times that the function exists."@en)
AnnotationAssertion(pbpko:IAO_0000118 pbpko:RO_0000079 "function_of"@en)
AnnotationAssertion(pbpko:IAO_0000118 pbpko:RO_0000079 "is function of"@en)
AnnotationAssertion(rdfs:label pbpko:RO_0000079 "function of"@en)
SubObjectPropertyOf(pbpko:RO_0000079 pbpko:RO_0000052)
InverseObjectProperties(pbpko:RO_0000079 pbpko:RO_0000085)
ObjectPropertyDomain(pbpko:RO_0000079 pbpko:BFO_0000034)

