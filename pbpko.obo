[Term]
id: OBI:0200172
name: partitioning objective
def: "A partitioning objective is a data transformation objective where the aim is to generate a collection of disjoint non-empty subsets whose union equals a non-empty input set." []
is_a: OBI:0200166 ! data transformation objective
