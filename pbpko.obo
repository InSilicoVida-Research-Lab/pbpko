is_a: BFO:0000017 ! realizable entity
relationship: RO:0000059 IAO:0000104 ! concretizes plan specification
property_value: IAO:0000117 "AR, BP, JM, MC, PRS" xsd:string

[Term]
id: OBI:0000450
name: regulatory agency
