    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="term:title"/>
        <Literal>PBPK ontology</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <Literal>PBPK Ontology</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="owl:versionInfo"/>
        <Literal>1.3.0</Literal>
    </Annotation>
